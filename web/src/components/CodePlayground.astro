---
// Playground avec 3 langages : curl / Python / JavaScript
// Montre une vraie intégration de l'API openswissdata
---
<div class="code-playground">
  <div class="code-tabs">
    <button class="code-tab active" data-lang="curl">
      <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true"><path d="M2 4h10M2 7h10M2 10h6" stroke="currentColor" stroke-width="1.4" stroke-linecap="round"/></svg>
      cURL
    </button>
    <button class="code-tab" data-lang="python">
      <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true"><circle cx="7" cy="7" r="5.5" stroke="currentColor" stroke-width="1.2"/><path d="M4 7h6M7 4v6" stroke="currentColor" stroke-width="1.2" stroke-linecap="round"/></svg>
      Python
    </button>
    <button class="code-tab" data-lang="js">
      <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true"><path d="M2 2h10v10H2z" stroke="currentColor" stroke-width="1.2" fill="none"/><path d="M5 8c0 1 .8 1.5 1.5 1.5S8 9 8 8V5M9 9.5c.3.3.8.5 1.3.5.7 0 1.2-.3 1.2-.8 0-1-2.5-.8-2.5-1.7 0-.5.5-.7 1-.7.4 0 .8.1 1 .3" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" fill="none"/></svg>
      JavaScript
    </button>
    <div class="code-tab-spacer"></div>
    <button class="code-copy" id="code-copy" type="button" title="Copier le code" aria-label="Copier le code dans le presse-papier">
      <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true"><rect x="3.5" y="3.5" width="7" height="7" rx="1.5" stroke="currentColor" stroke-width="1.2"/><path d="M5.5 1.5h6a1 1 0 011 1v6" stroke="currentColor" stroke-width="1.2" stroke-linecap="round"/></svg>
      <span id="code-copy-label">Copier</span>
    </button>
  </div>

  <div class="code-body">
    <pre is:raw class="code-pane active" data-lang="curl"><code><span class="cm">## 1. Charger une release du dataset TARES</span>
<span class="ck">curl</span> -H <span class="cs">"Authorization: Bearer $OSD_KEY"</span> \
  https://api.openswissdata.com/v1/tares/latest \
  -o tares.parquet

<span class="cm">## 2. Chercher un code HS particulier</span>
<span class="ck">curl</span> -H <span class="cs">"Authorization: Bearer $OSD_KEY"</span> \
  <span class="cs">"https://api.openswissdata.com/v1/tares/lookup?q=chocolat"</span></code></pre>

    <pre is:raw class="code-pane" data-lang="python"><code><span class="cm"># 1. Charger le dataset complet en mémoire</span>
<span class="ck">import</span> <span class="cn">pandas</span> <span class="ck">as</span> <span class="cn">pd</span>
df = pd.read_parquet(<span class="cs">"https://r2.openswissdata.com/tares/latest.parquet"</span>)

<span class="cm"># 2. Filtrer par mot-clé en français</span>
results = df[df[<span class="cs">"designation_fr"</span>].str.contains(<span class="cs">"chocolat"</span>, case=<span class="ck">False</span>)]
<span class="ck">print</span>(results[[<span class="cs">"hs8"</span>, <span class="cs">"designation_fr"</span>, <span class="cs">"duty_chf"</span>]])</code></pre>

    <pre is:raw class="code-pane" data-lang="js"><code><span class="cm">// 1. Récupérer la dernière version</span>
<span class="ck">import</span> { OpenSwissData } <span class="ck">from</span> <span class="cs">"@openswissdata/sdk"</span>;
<span class="ck">const</span> osd = <span class="ck">new</span> OpenSwissData({ apiKey: process.env.OSD_KEY });

<span class="cm">// 2. Chercher un code HS</span>
<span class="ck">const</span> results = <span class="ck">await</span> osd.tares.lookup({ q: <span class="cs">"chocolat"</span>, lang: <span class="cs">"fr"</span> });
console.log(results); <span class="cm">// [{hs8: "18063110", duty: 30.00, ...}]</span></code></pre>
  </div>

  <div class="code-result">
    <div class="code-result-label">Réponse JSON exemple</div>
    <pre is:raw><code>{
  <span class="ck">"hs8"</span>: <span class="cs">"18063110"</span>,
  <span class="ck">"hs6"</span>: <span class="cs">"180631"</span>,
  <span class="ck">"designation_fr"</span>: <span class="cs">"Chocolat fourré, en tablettes"</span>,
  <span class="ck">"designation_de"</span>: <span class="cs">"Schokolade, gefüllt, in Tafeln"</span>,
  <span class="ck">"designation_it"</span>: <span class="cs">"Cioccolato ripieno, in tavolette"</span>,
  <span class="ck">"duty_chf"</span>: <span class="cn">30.00</span>,
  <span class="ck">"duty_unit"</span>: <span class="cs">"100kg"</span>,
  <span class="ck">"preferential_regimes"</span>: { <span class="ck">"eu"</span>: <span class="cs">"free"</span>, <span class="ck">"efta"</span>: <span class="cs">"free"</span> }
}</code></pre>
  </div>
</div>

<style>
  .code-playground {
    background: #0F1115;
    border: 1px solid rgba(255,255,255,.08);
    border-radius: 16px;
    overflow: hidden;
    box-shadow: var(--shadow-lg);
  }

  .code-tabs {
    display: flex;
    background: rgba(255,255,255,.02);
    border-bottom: 1px solid rgba(255,255,255,.06);
    padding: 0 8px;
    align-items: center;
  }
  .code-tab-spacer { flex: 1; }

  .code-tab {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    background: transparent;
    border: none;
    color: rgba(255,255,255,.45);
    padding: 12px 14px;
    font-family: var(--font-mono);
    font-size: 12px;
    cursor: pointer;
    border-bottom: 2px solid transparent;
    transition: color .15s ease, border-color .15s ease;
  }
  .code-tab:hover { color: rgba(255,255,255,.75); }
  .code-tab.active {
    color: #FFB8BD;
    border-bottom-color: var(--color-accent);
  }

  .code-copy {
    background: rgba(255,255,255,.05);
    border: 1px solid rgba(255,255,255,.08);
    color: rgba(255,255,255,.7);
    padding: 6px 12px;
    border-radius: 6px;
    cursor: pointer;
    font-family: var(--font-sans);
    font-size: 12px;
    display: inline-flex;
    align-items: center;
    gap: 6px;
    margin: 8px;
    transition: all .15s ease;
  }
  .code-copy:hover {
    background: rgba(255,255,255,.08);
    color: white;
  }
  .code-copy.copied {
    background: rgba(110,231,183,.1);
    color: #6EE7B7;
    border-color: rgba(110,231,183,.2);
  }

  .code-body {
    position: relative;
    min-height: 220px;
  }

  .code-pane {
    display: none;
    margin: 0;
    padding: 24px 28px;
    overflow-x: auto;
    color: rgba(255,255,255,.85);
    font-family: var(--font-mono);
    font-size: 13px;
    line-height: 1.7;
  }
  .code-pane.active { display: block; }
  .code-pane code {
    font-family: inherit;
    color: inherit;
  }

  .code-result {
    border-top: 1px solid rgba(255,255,255,.06);
    background: rgba(255,255,255,.015);
    padding: 16px 28px 24px;
  }
  .code-result-label {
    font-family: var(--font-mono);
    font-size: 10px;
    text-transform: uppercase;
    letter-spacing: .08em;
    color: rgba(255,255,255,.4);
    margin-bottom: 10px;
  }
  .code-result pre {
    margin: 0;
    color: rgba(255,255,255,.8);
    font-family: var(--font-mono);
    font-size: 12px;
    line-height: 1.65;
    overflow-x: auto;
  }

  /* Syntax highlighting */
  .cm { color: rgba(255,255,255,.35); font-style: italic; }
  .ck { color: #C792EA; }
  .cs { color: #C3E88D; }
  .cn { color: #82AAFF; }

  @media (max-width: 640px) {
    .code-pane, .code-result { padding-left: 16px; padding-right: 16px; }
    .code-tab { padding: 10px 8px; font-size: 11px; }
    .code-tab svg { width: 12px; height: 12px; }
    .code-copy { padding: 5px 10px; font-size: 11px; margin: 6px; }
    .code-copy svg { width: 12px; height: 12px; }
  }
</style>

<script is:inline>
  const tabs = document.querySelectorAll('.code-tab');
  const panes = document.querySelectorAll('.code-pane');
  const copyBtn = document.getElementById('code-copy');
  const copyLabel = document.getElementById('code-copy-label');

  tabs.forEach(tab => {
    tab.addEventListener('click', () => {
      const lang = tab.dataset.lang;
      tabs.forEach(t => t.classList.toggle('active', t === tab));
      panes.forEach(p => p.classList.toggle('active', p.dataset.lang === lang));
    });
  });

  copyBtn.addEventListener('click', () => {
    const active = document.querySelector('.code-pane.active code');
    if (active) {
      navigator.clipboard.writeText(active.textContent).then(() => {
        copyBtn.classList.add('copied');
        copyLabel.textContent = 'Copié !';
        setTimeout(() => {
          copyBtn.classList.remove('copied');
          copyLabel.textContent = 'Copier';
        }, 1800);
      });
    }
  });
</script>
