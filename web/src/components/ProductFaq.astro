---
import { getLangFromPath, t, localizePath, localizePathOrFallback } from "../i18n/utils";

interface Props {
  productName: string;
  refundClause?: string;
  formatNote?: string;
}

const lang = getLangFromPath(Astro.url.pathname);
const {
  productName,
  refundClause = t("faq.default_refund", lang),
  formatNote = t("faq.default_format", lang),
} = Astro.props;

const L = (path: string) => localizePath(path, lang);
// Pages legal n'existent qu'en FR + DE (EN fallback DE)
const Llegal = (path: string) => localizePathOrFallback(path, lang, ["fr", "de"]);
---
<section class="ds-section reveal-v4">
  <div class="v4-section-eyebrow">
    <strong>{t("faq.eyebrow_label", lang)}</strong>
    <span class="sep">/</span>
    <span>{t("faq.eyebrow_sep", lang)}</span>
  </div>
  <h2 class="v4-section-h2">{t("faq.title_main", lang)} <span class="serif">{t("faq.title_accent", lang)}</span>.</h2>

  <div class="v4-faq-list">
    <details class="v4-faq-item reveal-v4">
      <summary>{t("faq.q1", lang)}</summary>
      <p>
        {t("faq.a1_part1", lang)}<strong>{t("faq.a1_sources", lang)}</strong>{t("faq.a1_part2", lang)}<a href={L("/compliance")}>{t("faq.a1_link_label", lang)}</a>{t("faq.a1_part3", lang)}
      </p>
    </details>

    <details class="v4-faq-item reveal-v4">
      <summary>{t("faq.q2", lang)}</summary>
      <p>
        {t("faq.a2_part1", lang)}<strong>{formatNote}</strong>{t("faq.a2_part2", lang)}
      </p>
    </details>

    <details class="v4-faq-item reveal-v4">
      <summary>{t("faq.q3", lang)}</summary>
      <p>
        {t("faq.a3_part1", lang)}<strong>{t("faq.a3_link1", lang)}</strong>{t("faq.a3_part2", lang)}<a href="/account">{t("faq.a3_link2", lang)}</a>{t("faq.a3_part3", lang)}
      </p>
    </details>

    <details class="v4-faq-item reveal-v4">
      <summary>{t("faq.q4", lang)}</summary>
      <p>
        {refundClause}{t("faq.a4_part1", lang)}<a href={`mailto:${t("faq.a4_email", lang)}`}>{t("faq.a4_email", lang)}</a>{t("faq.a4_part2", lang)}<a href={Llegal("/legal/cgv")}>{t("faq.a4_link", lang)}</a>{t("faq.a4_part3", lang)}
      </p>
    </details>

    <details class="v4-faq-item reveal-v4">
      <summary>{t("faq.q5", lang)}</summary>
      <p>
        {t("faq.a5_part1", lang)}<strong>{t("faq.a5_strong", lang)}</strong>{t("faq.a5_part2", lang)}
      </p>
    </details>
  </div>
</section>
