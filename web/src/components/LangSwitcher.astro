---
import { LANGS, LANG_LABELS, LANG_NAMES, getLangFromPath, localizePath } from "../i18n/utils";
import type { Lang } from "../i18n/utils";

interface Props {
  variant?: "compact" | "footer";
  /**
   * When true, the page only exists in French. The switcher
   * still appears, but DE/EN links point to the home of those
   * languages instead of producing a 404.
   */
  monolingual?: boolean;
}

const { variant = "compact", monolingual = false } = Astro.props;
const currentLang: Lang = getLangFromPath(Astro.url.pathname);
---
<div class={`lang-switcher lang-switcher-${variant}`} role="group" aria-label="Language">
  {LANGS.map((lang) => {
    const isCurrent = lang === currentLang;
    const targetMissing = monolingual && lang !== "fr" && lang !== currentLang;
    const href = targetMissing ? `/${lang}/` : localizePath(Astro.url.pathname, lang);
    const ariaLabel = targetMissing
      ? `${LANG_NAMES[lang]} — page non disponible, retour à l'accueil`
      : LANG_NAMES[lang];
    const cls = ["lang-link"];
    if (isCurrent) cls.push("is-current");
    if (targetMissing) cls.push("is-fallback");
    return (
      <a
        href={href}
        class={cls.join(" ")}
        hreflang={lang}
        aria-current={isCurrent ? "true" : undefined}
        aria-label={ariaLabel}
        title={targetMissing ? `${LANG_NAMES[lang]} (home)` : LANG_NAMES[lang]}
      >
        {LANG_LABELS[lang]}
      </a>
    );
  })}
</div>

<style>
  .lang-switcher {
    display: inline-flex;
    align-items: center;
    gap: 4px;
  }
  .lang-link {
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: .04em;
    padding: 3px 8px;
    border-radius: 4px;
    color: var(--color-ink-mute);
    text-decoration: none;
    border: 1px solid transparent;
    transition: color .15s ease, border-color .15s ease, background .15s ease;
  }
  .lang-link:hover {
    color: var(--color-ink);
  }
  .lang-link.is-current {
    color: var(--color-ink);
    border-color: var(--color-line);
    background: rgba(0,0,0,.02);
  }
  .lang-link.is-fallback {
    opacity: .55;
  }
  .lang-link.is-fallback:hover {
    opacity: 1;
  }

  /* Footer variant: slightly larger, sits in the bottom row */
  .lang-switcher-footer .lang-link {
    font-size: 12px;
    padding: 4px 10px;
  }

  @media (max-width: 720px) {
    .lang-switcher-compact .lang-link { padding: 2px 6px; }
  }
</style>
