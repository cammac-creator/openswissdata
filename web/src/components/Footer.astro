---
import { getLangFromPath, t, localizePath, localizePathOrFallback } from "../i18n/utils";
import LangSwitcher from "./LangSwitcher.astro";

interface Props {
  monolingual?: boolean;
}

const { monolingual = false } = Astro.props;
const year = new Date().getFullYear();
const lang = getLangFromPath(Astro.url.pathname);
const L = (path: string) => localizePath(path, lang);
const Llegal = (path: string) => localizePathOrFallback(path, lang, ["fr", "de"]);
---
<footer class="site-footer">
  <div class="footer-split">
    <div class="footer-split-left">
      <div class="footer-brand">
        <div class="footer-mark"><img src="/logo.png" alt="" width="64" height="64" /></div>
        <div>
          <div class="footer-name">openswissdata</div>
          <p class="footer-tag">
            {t("footer.tagline_line1", lang)}<br>
            <span class="serif">{t("footer.tagline_line2", lang)}</span>
          </p>
          <div class="footer-status">
            <span class="status-dot"></span>
            {t("footer.operational", lang)}
          </div>
        </div>
      </div>

      <div class="footer-cols">
        <div>
          <div class="footer-col-title">{t("footer.col_datasets", lang)}</div>
          <a href={L("/datasets/tares")}>{t("footer.link_tares", lang)}</a>
          <a href={L("/datasets/classifications")}>{t("footer.link_classifications", lang)}</a>
          <a href={L("/datasets/finma")}>{t("footer.link_finma", lang)}</a>
          <a href={L("/bundle")}>{t("footer.link_bundle", lang)}</a>
        </div>
        <div>
          <div class="footer-col-title">{t("footer.col_account", lang)}</div>
          <a href="/account">{t("footer.link_account", lang)}</a>
          <a href="/blog">{t("footer.link_blog", lang)}</a>
          <a href="mailto:contact@openswissdata.com">contact@openswissdata.com</a>
        </div>
        <div>
          <div class="footer-col-title">{t("footer.col_legal", lang)}</div>
          <a href={Llegal("/legal/cgv")}>{t("footer.link_cgv", lang)}</a>
          <a href={Llegal("/legal/privacy")}>{t("footer.link_privacy", lang)}</a>
          <a href={Llegal("/legal/provenance")}>{t("footer.link_provenance", lang)}</a>
          <a href={Llegal("/legal/sdr-policy")}>{t("footer.link_sdr", lang)}</a>
          <a href={L("/compliance")}>{t("footer.link_compliance", lang)}</a>
          <a href={Llegal("/legal/impressum")}>{t("footer.link_impressum", lang)}</a>
        </div>
      </div>
    </div>

    <div class="footer-split-right" aria-hidden="true">
      <img src="/og-tares.png" alt="" />
    </div>
  </div>

  <div class="footer-legal">
    <div class="container-wide">
      <div class="footer-affiliation">
        {t("footer.affiliation", lang)}
      </div>
      <div class="footer-disclaimer">
        <strong>{t("footer.disclaimer_title", lang)}</strong> {t("footer.disclaimer_body", lang)}
      </div>
      <div class="footer-bottom">
        <div>© {year} · Claude-Alain Martin · openswissdata.com</div>
        <div class="footer-bottom-right">
          <LangSwitcher variant="footer" monolingual={monolingual} />
          <a href="https://ibanforge.com" rel="noopener">{t("footer.studio", lang)}</a>
        </div>
      </div>
    </div>
  </div>
</footer>

<style>
  .site-footer {
    margin-top: 80px;
    background: var(--color-bg);
    border-top: 1px solid var(--color-ink);
  }

  /* ===== Split section: brand+cols / flipped banner ===== */
  .footer-split {
    display: grid;
    grid-template-columns: 1.5fr 1fr;
    min-height: 480px;
  }

  .footer-split-left {
    padding: 72px 56px 40px;
    display: flex;
    flex-direction: column;
    gap: 48px;
  }

  .footer-brand {
    display: flex;
    align-items: flex-start;
    gap: 18px;
  }
  .footer-mark {
    width: 64px;
    height: 64px;
    flex-shrink: 0;
  }
  .footer-mark img {
    width: 100%;
    height: 100%;
    object-fit: contain;
    display: block;
  }
  .footer-name {
    font-size: 26px;
    font-weight: 600;
    letter-spacing: -.025em;
    line-height: 1;
    margin-bottom: 10px;
  }
  .footer-tag {
    font-family: var(--font-serif);
    font-style: italic;
    font-size: 18px;
    line-height: 1.4;
    color: var(--color-ink);
    margin: 0 0 14px;
    max-width: 36ch;
  }
  .footer-status {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-family: var(--font-mono);
    font-size: 11px;
    text-transform: uppercase;
    letter-spacing: .04em;
    color: #22C55E;
    font-weight: 500;
  }
  .status-dot {
    width: 7px;
    height: 7px;
    background: #22C55E;
    border-radius: 50%;
    box-shadow: 0 0 0 3px rgba(34,197,94,.15);
    animation: footer-pulse 2.4s ease-in-out infinite;
  }
  @keyframes footer-pulse {
    0%, 100% { box-shadow: 0 0 0 3px rgba(34,197,94,.15); }
    50% { box-shadow: 0 0 0 8px rgba(34,197,94,0); }
  }

  .footer-cols {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 32px;
  }
  .footer-col-title {
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: .1em;
    text-transform: uppercase;
    color: var(--color-ink-mute);
    margin-bottom: 14px;
  }
  .footer-cols a {
    display: block;
    padding: 5px 0;
    color: var(--color-ink-soft);
    text-decoration: none;
    font-size: 13px;
    transition: color .15s ease;
  }
  .footer-cols a:hover { color: var(--accent); }

  /* Banner side — flipped horizontally so red square sits left */
  .footer-split-right {
    position: relative;
    background: var(--bg-soft, #F4F4F0);
    overflow: hidden;
  }
  .footer-split-right img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: right center;
    transform: scaleX(-1);
    animation: footer-banner-pan 18s ease-in-out infinite alternate;
    display: block;
  }
  @keyframes footer-banner-pan {
    0%   { transform: scaleX(-1) scale(1.02); }
    100% { transform: scaleX(-1) scale(1.05); }
  }
  /* Left fade — bannière fond se mêle doucement avec le contenu cream */
  .footer-split-right::before {
    content: '';
    position: absolute;
    left: 0; top: 0; bottom: 0;
    width: 60px;
    background: linear-gradient(90deg, var(--color-bg) 0%, transparent 100%);
    pointer-events: none;
    z-index: 2;
  }
  /* Right fade — bord externe adouci */
  .footer-split-right::after {
    content: '';
    position: absolute;
    right: 0; top: 0; bottom: 0;
    width: 120px;
    background: linear-gradient(270deg, var(--bg-soft, #F4F4F0) 0%, transparent 100%);
    pointer-events: none;
    z-index: 2;
  }

  /* ===== Legal section: full-width below split ===== */
  .footer-legal {
    border-top: 1px solid var(--color-line);
    background: var(--color-bg);
  }
  .footer-legal .container-wide {
    padding: 24px 36px 32px;
  }

  .footer-affiliation {
    padding: 12px 0 16px;
    font-size: 12px;
    color: var(--color-ink-mute);
    line-height: 1.55;
    font-style: italic;
  }

  .footer-disclaimer {
    padding: 20px 0;
    font-size: 12px;
    color: var(--color-ink-mute);
    line-height: 1.55;
    border-top: 1px solid var(--color-line);
    border-bottom: 1px solid var(--color-line);
  }
  .footer-disclaimer strong { color: var(--color-ink-soft); }

  .footer-bottom {
    padding-top: 24px;
    display: flex;
    justify-content: space-between;
    align-items: center;
    flex-wrap: wrap;
    gap: 16px;
    font-size: 13px;
    color: var(--color-ink-mute);
  }
  .footer-bottom-right {
    display: flex;
    align-items: center;
    gap: 16px;
    flex-wrap: wrap;
  }
  .footer-bottom a {
    color: var(--color-ink-soft);
    text-decoration: none;
  }
  .footer-bottom a:hover { color: var(--color-ink); }

  /* Responsive */
  @media (max-width: 1100px) {
    .footer-split { grid-template-columns: 1fr; }
    .footer-split-right { height: 280px; order: 2; }
    .footer-split-left { padding: 48px 36px 32px; gap: 36px; }
  }
  @media (max-width: 880px) {
    .footer-cols { grid-template-columns: 1fr 1fr; gap: 28px; }
  }
  @media (max-width: 540px) {
    .footer-cols { grid-template-columns: 1fr; }
    .footer-brand { flex-direction: column; gap: 14px; }
    .footer-mark { width: 56px; height: 56px; }
    .footer-name { font-size: 22px; }
    .footer-tag { font-size: 16px; }
  }
</style>
