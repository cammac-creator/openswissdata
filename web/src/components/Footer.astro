---
import { getLangFromPath, t, localizePath, localizePathOrFallback } from "../i18n/utils";
import LangSwitcher from "./LangSwitcher.astro";

interface Props {
  monolingual?: boolean;
}

const { monolingual = false } = Astro.props;
const year = new Date().getFullYear();
const lang = getLangFromPath(Astro.url.pathname);
const L = (path: string) => localizePath(path, lang);
// Pages legal are only available in FR + DE — EN visitors get DE.
const Llegal = (path: string) => localizePathOrFallback(path, lang, ["fr", "de"]);
// /compliance is available in FR + DE + EN.
---
<footer class="site-footer">
  <div class="container-wide">
    <div class="footer-top">
      <div class="footer-brand">
        <div class="footer-logo">
          <span class="logo-mark">o</span>
          <span class="logo-text">openswissdata</span>
        </div>
        <p class="footer-tag">
          {t("footer.tagline_line1", lang)}<br>
          <span class="serif">{t("footer.tagline_line2", lang)}</span>
        </p>
        <div class="footer-status">
          <span class="status-dot"></span>
          {t("footer.operational", lang)}
        </div>
      </div>

      <div class="footer-cols">
        <div>
          <div class="footer-col-title">{t("footer.col_datasets", lang)}</div>
          <a href={L("/datasets/tares")}>{t("footer.link_tares", lang)}</a>
          <a href={L("/datasets/classifications")}>{t("footer.link_classifications", lang)}</a>
          <a href={L("/datasets/finma")}>{t("footer.link_finma", lang)}</a>
          <a href={L("/bundle")}>{t("footer.link_bundle", lang)}</a>
        </div>
        <div>
          <div class="footer-col-title">{t("footer.col_account", lang)}</div>
          <a href="/account">{t("footer.link_account", lang)}</a>
          <a href="/blog">{t("footer.link_blog", lang)}</a>
          <a href="mailto:contact@openswissdata.com">contact@openswissdata.com</a>
        </div>
        <div>
          <div class="footer-col-title">{t("footer.col_legal", lang)}</div>
          <a href={Llegal("/legal/cgv")}>{t("footer.link_cgv", lang)}</a>
          <a href={Llegal("/legal/privacy")}>{t("footer.link_privacy", lang)}</a>
          <a href={Llegal("/legal/provenance")}>{t("footer.link_provenance", lang)}</a>
          <a href={Llegal("/legal/sdr-policy")}>{t("footer.link_sdr", lang)}</a>
          <a href={L("/compliance")}>{t("footer.link_compliance", lang)}</a>
          <a href={Llegal("/legal/impressum")}>{t("footer.link_impressum", lang)}</a>
        </div>
      </div>
    </div>

    <div class="footer-affiliation">
      {t("footer.affiliation", lang)}
    </div>

    <div class="footer-disclaimer">
      <strong>{t("footer.disclaimer_title", lang)}</strong> {t("footer.disclaimer_body", lang)}
    </div>

    <div class="footer-bottom">
      <div>© {year} · Claude-Alain Martin · openswissdata.com</div>
      <div class="footer-bottom-right">
        <LangSwitcher variant="footer" monolingual={monolingual} />
        <a href="https://ibanforge.com" rel="noopener">{t("footer.studio", lang)}</a>
      </div>
    </div>
  </div>
</footer>

<style>
  .site-footer {
    background: var(--color-bg);
    border-top: 1px solid var(--color-line);
    padding: 80px 0 40px;
    margin-top: 80px;
  }

  .footer-top {
    display: grid;
    grid-template-columns: 1fr 2fr;
    gap: 80px;
    padding-bottom: 56px;
  }

  .footer-brand .footer-logo {
    display: flex;
    align-items: center;
    gap: 10px;
    font-weight: 700;
    font-size: 17px;
    margin-bottom: 18px;
  }
  .footer-logo .logo-mark {
    width: 28px;
    height: 28px;
    border-radius: 7px;
    background: var(--color-ink);
    color: var(--color-bg);
    display: grid;
    place-items: center;
    font-family: var(--font-serif);
    font-size: 18px;
    font-style: italic;
    transform: rotate(-4deg);
  }
  .footer-tag {
    font-family: var(--font-serif);
    font-style: italic;
    font-size: 22px;
    line-height: 1.3;
    color: var(--color-ink);
    margin: 0 0 24px;
  }
  .footer-status {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-size: 13px;
    color: var(--color-ink-soft);
  }
  .status-dot {
    width: 8px; height: 8px;
    background: #22C55E;
    border-radius: 50%;
    box-shadow: 0 0 0 3px rgba(34,197,94,.15);
    animation: pulse 2.4s ease-in-out infinite;
  }

  .footer-cols {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 32px;
  }

  .footer-col-title {
    font-family: var(--font-mono);
    font-size: 11px;
    text-transform: uppercase;
    letter-spacing: .08em;
    color: var(--color-ink-mute);
    margin-bottom: 16px;
  }

  .footer-cols a {
    display: block;
    padding: 6px 0;
    color: var(--color-ink-soft);
    text-decoration: none;
    font-size: 14px;
    transition: color .15s ease;
  }
  .footer-cols a:hover { color: var(--color-ink); }

  .footer-affiliation {
    padding: 12px 0 16px;
    font-size: 12px;
    color: var(--color-ink-mute);
    line-height: 1.55;
    font-style: italic;
    border-top: 1px solid var(--color-line);
  }

  .footer-disclaimer {
    padding: 20px 0;
    font-size: 12px;
    color: var(--color-ink-mute);
    line-height: 1.55;
    border-top: 1px solid var(--color-line);
    border-bottom: 1px solid var(--color-line);
  }
  .footer-disclaimer strong { color: var(--color-ink-soft); }

  .footer-bottom {
    padding-top: 24px;
    display: flex;
    justify-content: space-between;
    align-items: center;
    flex-wrap: wrap;
    gap: 16px;
    font-size: 13px;
    color: var(--color-ink-mute);
  }
  .footer-bottom-right {
    display: flex;
    align-items: center;
    gap: 16px;
    flex-wrap: wrap;
  }
  .footer-bottom a {
    color: var(--color-ink-soft);
    text-decoration: none;
  }
  .footer-bottom a:hover { color: var(--color-ink); }

  @media (max-width: 880px) {
    .footer-top { grid-template-columns: 1fr; gap: 48px; }
    .footer-cols { grid-template-columns: 1fr 1fr; gap: 32px; }
  }
  @media (max-width: 540px) {
    .footer-cols { grid-template-columns: 1fr; }
  }
</style>
