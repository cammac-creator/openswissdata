        border: 1.5px solid var(--blue);
      }
      .aside-blue .aside-mark {
        background: var(--blue);
        color: white;
      }

      /* ─── Problem chests ─── */
      .problem-chests {
        display: grid;
        grid-template-columns: 1fr;
        gap: 1.5rem;
        margin: 2.5rem 0;
      }
      @media (min-width: 720px) {
        .problem-chests { grid-template-columns: repeat(3, 1fr); }
      }
      .problem-chest {
        background: var(--bg);
        border: 2px solid var(--ink);
        border-radius: 14px;
        padding: 1.5rem;
        box-shadow: 4px 4px 0 0 var(--gold);
        transition: transform 0.2s, box-shadow 0.2s;
      }
      .problem-chest:hover {
        transform: translate(-2px, -2px);
        box-shadow: 6px 6px 0 0 var(--red);
      }
      .problem-chest-illu {
        width: 100%;
        margin-bottom: 1rem;
        text-align: center;
      }
      .problem-chest-illu svg {
        width: 100%;
        max-width: 200px;
        height: auto;
      }
      .problem-chest h3 {
        font-family: var(--font-display);
        font-size: 1.3rem;
        font-weight: 600;
        color: var(--ink);
        margin: 0 0 0.6rem;
        letter-spacing: -0.01em;
      }
      .problem-chest p {
        margin: 0;
        font-size: 0.98rem;
        line-height: 1.5;
        color: var(--ink-soft);
      }
      .messy-paper { animation: shake-paper 4s ease-in-out infinite; }
      .messy-paper-2 { animation: shake-paper 4s 0.4s ease-in-out infinite; }
      @keyframes shake-paper {
        0%, 100% { transform: translate(110px, 50px) rotate(0); }
        25% { transform: translate(110px, 50px) rotate(-3deg); }
        75% { transform: translate(110px, 50px) rotate(3deg); }
      }
      .scattered { animation: scatter 5s ease-in-out infinite; }
      @keyframes scatter {
        0%, 100% { transform: translate(50px, 30px) scale(1); }
        50% { transform: translate(50px, 28px) scale(1.02); }
      }

      /* ─── Workshop ─── */
      .workshop {
        margin: 3rem 0;
      }
      .workshop svg {
        width: 100%;
        max-width: 720px;
        height: auto;
        display: block;
        margin: 0 auto;
        border: 2px solid var(--ink);
        border-radius: 16px;
        background: #FFF8E7;
        box-shadow: 8px 8px 0 0 var(--blue);
      }
      .conveyor-belts circle {
        animation: roll 2s linear infinite;
      }
      @keyframes roll {
        0%, 100% { opacity: 0.7; }
        50% { opacity: 1; }
      }
      .led { animation: led-blink 1.4s infinite; }
      .led-1 { animation-delay: 0s; }
      .led-2 { animation-delay: 0.5s; }
      .led-3 { animation-delay: 1s; }
      @keyframes led-blink {
        0%, 100% { opacity: 1; }
        50% { opacity: 0.3; }
      }
      .steam circle {
        animation: steam-rise 2.4s ease-out infinite;
      }
      .steam circle:nth-child(2) { animation-delay: 0.3s; }
      .steam circle:nth-child(3) { animation-delay: 0.6s; }
      .steam circle:nth-child(4) { animation-delay: 0.9s; }
      .steam circle:nth-child(5) { animation-delay: 1.2s; }
      @keyframes steam-rise {
        0% { opacity: 0; transform: translateY(0) scale(0.6); }
        50% { opacity: 0.7; }
        100% { opacity: 0; transform: translateY(-30px) scale(1.2); }
      }
      .enter-paper {
        animation: enter-conveyor 4s ease-in-out infinite;
      }
      @keyframes enter-conveyor {
        0% { transform: translate(20px, 160px); opacity: 0; }
        15%, 35% { transform: translate(170px, 160px); opacity: 1; }
        50%, 100% { transform: translate(220px, 160px); opacity: 0; }
      }
      .exit-box {
        animation: exit-conveyor 4s ease-in-out infinite;
      }
      .exit-box-1 { animation-delay: 0.4s; }
      .exit-box-2 { animation-delay: 0.4s; }
      .exit-box-3 { animation-delay: 0.4s; }
      @keyframes exit-conveyor {
        0%, 50% { opacity: 0; }
        60% { opacity: 1; }
        100% { opacity: 1; }
      }

      /* ─── Treasures ─── */
      .treasures {
        display: grid;
        grid-template-columns: 1fr;
        gap: 1.25rem;
        margin: 2.5rem 0;
      }
      @media (min-width: 720px) {
        .treasures { grid-template-columns: repeat(2, 1fr); }
      }
      .treasure {
        background: var(--bg);
        border: 2px solid var(--ink);
        border-radius: 14px;
        padding: 2rem 1.5rem;
        position: relative;
        box-shadow: 5px 5px 0 0 var(--gold);
        transition: transform 0.2s, box-shadow 0.2s;
      }
      .treasure:hover {
        transform: translate(-2px, -2px);
        box-shadow: 7px 7px 0 0 var(--red);
      }
      .treasure-emoji {
        font-size: 3rem;
        line-height: 1;
        margin-bottom: 0.6rem;
        animation: emoji-pop 4s ease-in-out infinite;
        display: inline-block;
      }
      .treasure:nth-child(2) .treasure-emoji { animation-delay: 0.5s; }
      .treasure:nth-child(3) .treasure-emoji { animation-delay: 1s; }
      .treasure:nth-child(4) .treasure-emoji { animation-delay: 1.5s; }
      @keyframes emoji-pop {
        0%, 100% { transform: scale(1) rotate(0); }
        50% { transform: scale(1.08) rotate(-4deg); }
      }
      .treasure-tag {
        font-family: var(--font-display);
        font-size: 0.7rem;
        text-transform: uppercase;
        letter-spacing: 0.14em;
        color: var(--ink-mute);
        font-weight: 500;
        margin-bottom: 0.4rem;
      }
      .treasure h3 {
        font-family: var(--font-display);
        font-size: 1.6rem;
        font-weight: 700;
        color: var(--ink);
        margin: 0 0 0.7rem;
        letter-spacing: -0.01em;
      }
      .treasure p {
        margin: 0 0 1.2rem;
        font-size: 0.98rem;
        color: var(--ink-soft);
        line-height: 1.55;
      }
      .treasure-stats {
        display: flex;
        gap: 1.5rem;
        padding: 0.8rem 0;
        border-top: 1px dashed var(--line);
        border-bottom: 1px dashed var(--line);
        margin-bottom: 1rem;
      }
      .treasure-stats > div {
        display: flex;
        flex-direction: column;
      }
      .stat-num {
        font-family: var(--font-display);
        font-size: 1.4rem;
        font-weight: 700;
        color: var(--ink);
        line-height: 1;
      }
      .stat-strike {
        text-decoration: line-through;
        color: var(--ink-mute);
      }
      .stat-bundle {
        color: var(--red);
      }
      .stat-lab {
        font-size: 0.78rem;
        color: var(--ink-mute);
        margin-top: 0.2rem;
      }
      .treasure-price {
        display: flex;
        flex-direction: column;
        gap: 0.2rem;
      }
      .price-amt {
        font-family: var(--font-display);
        font-size: 1.6rem;
        font-weight: 700;
        color: var(--red);
        line-height: 1;
      }
      .price-sub {
        font-size: 0.85rem;
        color: var(--ink-mute);
      }
      .treasure-bundle {
        background: var(--gold-soft);
        border-color: var(--red);
        box-shadow: 5px 5px 0 0 var(--red);
      }
      .treasure-bundle:hover {
        box-shadow: 7px 7px 0 0 var(--ink);
      }
      .bundle-ribbon {
        position: absolute;
        top: -14px;
        right: 16px;
        background: var(--red);
        color: white;
        font-family: var(--font-display);
        font-size: 0.78rem;
        font-weight: 600;
        padding: 0.4rem 0.8rem;
        border-radius: 999px;
        letter-spacing: 0.04em;
        box-shadow: 2px 2px 0 0 var(--ink);
      }
      .treasure-price-bundle .price-amt {
        font-size: 2rem;
      }

      /* ─── Customers ─── */
      .customers {
        display: grid;
        grid-template-columns: 1fr;
        gap: 1rem;
        margin: 2.5rem 0;
      }
      @media (min-width: 600px) {
        .customers { grid-template-columns: repeat(2, 1fr); }
      }
      @media (min-width: 980px) {
        .customers { grid-template-columns: repeat(4, 1fr); }
      }
      .customer {
        background: var(--bg);
        border: 2px solid var(--ink);
        border-radius: 14px;
        padding: 1.5rem 1.25rem;
        text-align: center;
        box-shadow: 4px 4px 0 0 var(--blue);
        transition: transform 0.2s, box-shadow 0.2s;
      }
      .customer:hover {
        transform: translate(-2px, -2px);
        box-shadow: 6px 6px 0 0 var(--red);
      }
      .customer-face {
        font-size: 3rem;
        line-height: 1;
        margin-bottom: 0.6rem;
        display: inline-block;
        animation: face-wobble 3s ease-in-out infinite;
      }
      .customer:nth-child(2) .customer-face { animation-delay: 0.4s; }
      .customer:nth-child(3) .customer-face { animation-delay: 0.8s; }
      .customer:nth-child(4) .customer-face { animation-delay: 1.2s; }
      @keyframes face-wobble {
        0%, 100% { transform: rotate(0); }
        25% { transform: rotate(-6deg); }
        75% { transform: rotate(6deg); }
      }
      .customer h3 {
        font-family: var(--font-display);
        font-size: 1.15rem;
        font-weight: 600;
        margin: 0 0 0.5rem;
        color: var(--ink);
      }
      .customer p {
        margin: 0 0 1rem;
        font-size: 0.92rem;
        color: var(--ink-soft);
        line-height: 1.5;
      }
      .customer-tag {
        display: inline-block;
        padding: 0.3rem 0.7rem;
        background: var(--gold-soft);
        color: var(--ink);
        border: 1.5px solid var(--gold);
        border-radius: 999px;
        font-family: var(--font-display);
        font-size: 0.78rem;
        font-weight: 500;
      }

      /* ─── Piggy / tirelire ─── */
      .piggy-section {
        display: grid;
        grid-template-columns: 1fr;
        gap: 2rem;
        margin: 3rem 0;
        align-items: center;
      }
      @media (min-width: 900px) {
        .piggy-section { grid-template-columns: 360px 1fr; gap: 3rem; }
      }

      .piggy-illu {
        background: var(--bg);
        border: 2px solid var(--ink);
        border-radius: 16px;
        padding: 1rem;
        box-shadow: 8px 8px 0 0 var(--gold);
      }
      .piggy-illu svg { width: 100%; height: auto; }
      .coin {
        animation: coin-drop 3s ease-in infinite;
        opacity: 0;
      }
      .coin-a { animation-delay: 0s; }
      .coin-b { animation-delay: 1s; }
      .coin-c { animation-delay: 2s; }
      @keyframes coin-drop {
        0% { transform: translateY(0); opacity: 0; }
        10% { opacity: 1; }
        45% { transform: translateY(170px); opacity: 1; }
        55% { transform: translateY(160px); opacity: 0; }
        100% { transform: translateY(0); opacity: 0; }
      }
      .cling {
        animation: cling-pop 3s ease-out infinite;
        opacity: 0;
        transform-origin: center;
      }
      @keyframes cling-pop {
        0%, 40% { opacity: 0; transform: scale(0.6) rotate(-10deg); }
        47% { opacity: 1; transform: scale(1.2) rotate(8deg); }
        55% { opacity: 1; transform: scale(1) rotate(-3deg); }
        80%, 100% { opacity: 0; transform: scale(1) rotate(0); }
      }

      .piggy-numbers {
        display: flex;
        flex-direction: column;
        gap: 1.25rem;
      }
      .calc-card {
        background: var(--bg);
        border: 2px solid var(--ink);
        border-radius: 14px;
        padding: 1.75rem;
        box-shadow: 5px 5px 0 0 var(--red);
      }
      .calc-eyebrow {
        font-family: var(--font-display);
        font-size: 0.78rem;
        text-transform: uppercase;
        letter-spacing: 0.14em;
        color: var(--red);
        font-weight: 600;
        margin-bottom: 1rem;
      }
      .calc-row {
        display: flex;
        align-items: baseline;
        gap: 1rem;
        padding: 0.6rem 0;
        border-bottom: 1px dashed var(--line);
      }
      .calc-row:last-of-type { border-bottom: none; }
      .calc-row-total {
        margin-top: 0.4rem;
        padding-top: 1rem;
        border-top: 2px solid var(--ink);
        border-bottom: none;
      }
      .calc-num {
        font-family: var(--font-display);
        font-size: 1.6rem;
        font-weight: 700;
        color: var(--ink);
        min-width: 2.4em;
      }
      .calc-total {
        color: var(--red);
        font-size: 2.2rem;
      }
      .calc-text {
        color: var(--ink-soft);
        font-size: 1rem;
      }
      .calc-note {
        margin-top: 1.2rem;
        padding-top: 1rem;
        border-top: 1px dashed var(--line);
        font-size: 0.92rem;
        color: var(--ink-soft);
        line-height: 1.55;
        font-style: italic;
      }

      .calc-side {
        background: var(--blue-soft);
        border: 2px solid var(--blue);
        border-radius: 14px;
        padding: 1.5rem;
      }
      .calc-side-eyebrow {
        font-family: var(--font-display);
        font-size: 0.78rem;
        text-transform: uppercase;
        letter-spacing: 0.14em;
        color: var(--blue);
        font-weight: 600;
        margin-bottom: 0.7rem;
      }
      .calc-side p {
        margin: 0;
        font-size: 0.98rem;
        line-height: 1.55;
        color: var(--ink);
      }
      .calc-side strong {
        background: white;
        padding: 0 4px;
      }

      /* ─── Final ─── */
      .chapter-final {
        text-align: center;
        padding: 6rem 1.5rem 7rem;
      }
      .final-lede {
        font-family: var(--font-body);
        font-size: 1.15rem;
        font-style: italic;
        color: var(--ink-soft);
        max-width: 32rem;
        margin: 0 auto 2.5rem;
        line-height: 1.55;
      }
      .final-ctas {
        display: flex;
        flex-direction: column;
        gap: 0.75rem;
        align-items: center;
        margin-bottom: 3rem;
      }
      @media (min-width: 540px) {
        .final-ctas { flex-direction: row; justify-content: center; }
      }
      .final-cta {
        display: inline-flex;
        align-items: center;
        gap: 0.6rem;
        padding: 1rem 1.7rem;
        background: var(--red);
        color: white;
        border-radius: 999px;
        font-family: var(--font-display);
        font-weight: 600;
        font-size: 1.05rem;
        text-decoration: none;
        box-shadow: 4px 4px 0 0 var(--ink);
        transition: transform 0.2s, box-shadow 0.2s;
      }
      .final-cta:hover {
        transform: translate(-2px, -2px);
        box-shadow: 6px 6px 0 0 var(--ink);
      }
      .final-cta-ghost {
        display: inline-flex;
        align-items: center;
        padding: 1rem 1.7rem;
        background: transparent;
        color: var(--ink);
        border: 2px solid var(--ink);
        border-radius: 999px;
        font-family: var(--font-display);
        font-weight: 600;
        font-size: 1.05rem;
        text-decoration: none;
        transition: background 0.2s, color 0.2s;
      }
      .final-cta-ghost:hover {
        background: var(--ink);
        color: white;
      }
      .final-stamp {
        margin: 2rem 0;
        display: flex;
        justify-content: center;
        animation: stamp-tilt 3s ease-in-out infinite;
        transform-origin: center;
      }
      @keyframes stamp-tilt {
        0%, 100% { transform: rotate(-4deg); }
        50% { transform: rotate(4deg); }
      }
      .final-signature {
        font-family: var(--font-script);
        font-size: 2.2rem;
        color: var(--red);
        font-weight: 600;
        margin: 1rem 0 0;
      }

      @media (prefers-reduced-motion: reduce) {
        .papa, .chest, .messy-paper, .messy-paper-2, .scattered,
        .conveyor-belts circle, .led, .steam circle,
        .enter-paper, .exit-box, .treasure-emoji, .customer-face,
        .coin, .cling, .scroll-cue, .final-stamp {
          animation: none !important;
        }
      }
    </style>
  </body>
</html>
