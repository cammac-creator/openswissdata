---
import BaseLayout from "../../layouts/BaseLayout.astro";
// Placeholder — will be replaced with real Stripe Checkout URL once Task 1.6 + 4.4 are complete.
const STRIPE_CHECKOUT_URL = "/api/checkout/session?dataset=tares";
---
<BaseLayout
  title="TARES Dataset — Swiss Customs Tariff (HS8) | openswissdata"
  description="Normalized Swiss customs tariff codes (HS8) in CSV, JSON, Parquet, SQL. ~6 000 codes with FR/DE/IT/EN designations, duties, preferential regimes. 299 CHF one-shot."
>
  <section class="max-w-4xl mx-auto px-6 py-16">
    <nav class="text-sm text-slate-500 mb-4">
      <a href="/" class="hover:underline">Home</a> · <a href="/bundle" class="hover:underline">All datasets</a> · <span>TARES</span>
    </nav>

    <div class="bg-amber-50 border border-amber-200 rounded-lg p-4 mb-6 text-sm">
      <p class="font-semibold text-amber-900 mb-2">&#9888; Non-officiel · Nicht-offiziell · Non-official</p>
      <p class="text-amber-900">
        Seules les publications officielles de la Chancellerie fédérale et du BAZG font foi.
        Source autoritative : <a href="https://xtares.admin.ch/" target="_blank" rel="noopener" class="underline">xtares.admin.ch</a>.
      </p>
    </div>

    <div class="flex items-baseline justify-between flex-wrap gap-4 mb-2">
      <h1 class="text-4xl font-bold">TARES — Swiss Customs Tariff</h1>
      <div class="text-3xl font-bold text-indigo-600">CHF 299</div>
    </div>

    <p class="text-lg text-slate-600 mb-8">
      ~6 000 HS8 codes with FR/DE/IT/EN designations, MFN duties, preferential regimes (EU/EFTA/UK/CN), and cross-walks to international HS6. Weekly delta updates. One-shot purchase, 360 days of updates included.
    </p>

    <div class="grid md:grid-cols-2 gap-4 mb-10 text-sm">
      <div class="border border-slate-200 rounded-lg p-4">
        <div class="font-semibold mb-1 text-slate-900">Formats included</div>
        <div class="text-slate-600">CSV · JSON · Parquet · SQL · JSON Schema · README · SHA-256 checksums · License</div>
      </div>
      <div class="border border-slate-200 rounded-lg p-4">
        <div class="font-semibold mb-1 text-slate-900">Updates</div>
        <div class="text-slate-600">Weekly delta since BAZG updates · 360 days included · renewal CHF 120/year</div>
      </div>
    </div>

    <h2 class="text-2xl font-semibold mb-3">What's in the dataset</h2>
    <div class="overflow-x-auto mb-8">
      <table class="min-w-full text-sm border border-slate-200 rounded-lg">
        <thead class="bg-slate-50">
          <tr class="text-left">
            <th class="px-4 py-2 border-b border-slate-200">Field</th>
            <th class="px-4 py-2 border-b border-slate-200">Type</th>
            <th class="px-4 py-2 border-b border-slate-200">Example</th>
          </tr>
        </thead>
        <tbody>
          <tr><td class="px-4 py-2 font-mono">hs8</td><td class="px-4 py-2 text-slate-600">string (8 digits)</td><td class="px-4 py-2 font-mono">84820010</td></tr>
          <tr><td class="px-4 py-2 font-mono">hs6</td><td class="px-4 py-2 text-slate-600">string (6 digits)</td><td class="px-4 py-2 font-mono">848200</td></tr>
          <tr><td class="px-4 py-2 font-mono">designation_fr</td><td class="px-4 py-2 text-slate-600">string</td><td class="px-4 py-2">Roulements à billes, à contact radial</td></tr>
          <tr><td class="px-4 py-2 font-mono">designation_de</td><td class="px-4 py-2 text-slate-600">string</td><td class="px-4 py-2">Kugellager, mit radialer Berührung</td></tr>
          <tr><td class="px-4 py-2 font-mono">unit_stat</td><td class="px-4 py-2 text-slate-600">string</td><td class="px-4 py-2 font-mono">kg</td></tr>
          <tr><td class="px-4 py-2 font-mono">duty_mfn_chf_per_100kg</td><td class="px-4 py-2 text-slate-600">number</td><td class="px-4 py-2 font-mono">0</td></tr>
          <tr><td class="px-4 py-2 font-mono">preferential_regimes</td><td class="px-4 py-2 text-slate-600">object</td><td class="px-4 py-2 font-mono">&#123;"eu":"free","efta":"free"&#125;</td></tr>
          <tr><td class="px-4 py-2 font-mono">restrictions_codes</td><td class="px-4 py-2 text-slate-600">string[]</td><td class="px-4 py-2 font-mono">["REACH"]</td></tr>
        </tbody>
      </table>
    </div>

    <div class="bg-slate-50 border border-slate-200 rounded-lg p-6 mb-10">
      <h3 class="font-semibold mb-2">Free sample — 100 rows (CSV)</h3>
      <p class="text-sm text-slate-600 mb-3">Try before you buy. 100-row curated preview with diverse chapters.</p>
      <a href="/samples/tares-sample.csv" download class="text-indigo-600 font-medium hover:underline">↓ Download tares-sample.csv</a>
    </div>

    <h2 class="text-2xl font-semibold mb-3">Who is this for?</h2>
    <ul class="list-disc pl-6 space-y-2 text-slate-700 mb-8">
      <li><strong>Customs brokers &amp; declarants</strong> — classify imports/exports CH-EU consistently</li>
      <li><strong>ERP customs modules</strong> — SAP GTS, Descartes, Thomson Reuters ONESOURCE integrations</li>
      <li><strong>E-commerce cross-border</strong> — CH-EU DDP/DAP HS8 resolution at checkout</li>
      <li><strong>Data teams</strong> — Swiss tariff reference tables for analytics &amp; reporting</li>
    </ul>

    <h2 class="text-2xl font-semibold mb-3">Why not just scrape xtares.admin.ch?</h2>
    <p class="text-slate-700 mb-8">
      You can. It'll take you 20-40 hours of ETL work every time, fighting non-machine-readable tables, broken UTF-8, and inconsistent hierarchies. At CHF 120/hour of engineering time that's CHF 2 400 - 4 800. <strong>CHF 299 is the better choice.</strong>
    </p>

    <div class="border-t border-slate-200 pt-10 mt-10 text-center">
      <a href={STRIPE_CHECKOUT_URL} class="inline-block px-10 py-4 rounded-lg bg-indigo-600 hover:bg-indigo-700 text-white text-lg font-semibold transition-colors">
        Buy TARES — CHF 299
      </a>
      <p class="text-xs text-slate-500 mt-3">Secure checkout via Stripe · Instant download by email · 14-day refund if not downloaded</p>
    </div>

    <p class="mt-8 text-xs text-slate-500">
      TARES-specific terms: governing law Swiss, jurisdiction Bern. See full license terms in the bundle LICENSE.txt.
    </p>
  </section>
</BaseLayout>
