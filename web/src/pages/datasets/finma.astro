---
import BaseLayout from "../../layouts/BaseLayout.astro";
import FinmaLookup from "../../components/FinmaLookup.astro";
import TrustStrip from "../../components/TrustStrip.astro";
---
<BaseLayout
  title="Registre FINMA unifié — Conformité financière suisse | openswissdata"
  description="Les 10 listes publiques d'autorisations FINMA consolidées sous un schéma unique. Banques, assurances, PSPs, gestionnaires d'actifs, SRO. Enrichi UID + LEI. 299 CHF one-shot."
>
<div class="bg-grid"></div>

<section class="v4-hero ds-page">
  <div class="container-v4">
    <nav class="ds-breadcrumb">
      <a href="/">accueil</a>
      <span class="sep">·</span>
      <a href="/bundle">datasets</a>
      <span class="sep">·</span>
      <span class="current">FINMA Registry</span>
    </nav>

    <div class="v4-hero-grid">
      <div>
        <div class="v4-eyebrow reveal-v4">
          <span>FINMA · Registre unifié</span>
          <span style="opacity:.4">·</span>
          <span>Permission demandée 2026-04-17</span>
        </div>

        <h1 class="v4-h1 reveal-v4" data-delay="1">
          10 listes FINMA,<br>
          <span class="accent">un seul registre.</span>
        </h1>

        <p class="v4-lede reveal-v4" data-delay="2">
          Toutes les institutions financières autorisées par la FINMA, consolidées sous un schéma unifié :
          banques, assurances, PSPs, gestionnaires d'actifs, courtiers, SRO. <strong>Enrichi UID suisse + LEI international.</strong>
          Mises à jour hebdomadaires avec changelog 90 jours.
        </p>

        <div class="v4-spec-row reveal-v4" data-delay="3">
          <div class="v4-spec">
            <div class="v4-spec-label">Listes</div>
            <div class="v4-spec-value">10 unifiées</div>
          </div>
          <div class="v4-spec">
            <div class="v4-spec-label">Entités</div>
            <div class="v4-spec-value">~2 912</div>
          </div>
          <div class="v4-spec">
            <div class="v4-spec-label">Mises à jour</div>
            <div class="v4-spec-value">Hebdomadaires</div>
          </div>
        </div>

        <div class="v4-cta-row reveal-v4" data-delay="4">
          <a href="#acheter" class="v4-btn v4-btn-primary">Acheter — 299 CHF <span class="arrow">→</span></a>
          <a href="/samples/finma-sample.csv" download class="v4-btn v4-btn-secondary">Échantillon CSV</a>
        </div>

        <div class="v4-permission-line reveal-v4" data-delay="5">
          <span><strong>Source :</strong> FINMA</span>
          <span style="opacity:.4">·</span>
          <span>Listes publiques officielles</span>
          <span style="opacity:.4">·</span>
          <span><strong>For :</strong> Berne</span>
        </div>
      </div>

      <div class="ds-price-box reveal-v4" data-delay="2">
        <div class="ds-price-box-label">One-shot</div>
        <div class="ds-price-box-amount">299<span class="ds-price-box-currency">CHF</span></div>
        <div class="ds-price-box-renew">+120 CHF/an mises à jour (optionnel) · 360 jours d'updates inclus</div>
      </div>
    </div>
  </div>
</section>

<TrustStrip
  sources={["FINMA", "UID Registry", "GLEIF (LEI)"]}
  badges={["10 listes consolidées", "Manifest signé Ed25519", "Horodatage RFC-3161"]}
/>

<section class="v4-datasets ds-page">
  <div class="container-v4">
    <div class="ds-meta-grid">
      <div class="ds-meta-card reveal-v4">
        <div class="ds-meta-label">Formats inclus</div>
        <div class="ds-meta-value">CSV (unifié + par type) · JSON · Parquet · SQL · changelog 90 jours · JSON Schema · README · LICENSE · SHA-256</div>
      </div>
      <div class="ds-meta-card reveal-v4" data-delay="1">
        <div class="ds-meta-label">Mises à jour</div>
        <div class="ds-meta-value">Diff hebdomadaire + changelog 90 jours · 360 jours inclus · renouvellement 120 CHF/an</div>
      </div>
    </div>

    <section class="ds-section reveal-v4">
      <div class="v4-section-eyebrow">
        <strong>Périmètre</strong>
        <span class="sep">/</span>
        <span>10 types d'entités FINMA</span>
      </div>
      <h2 class="v4-section-h2">10 <span class="serif">types d'entités</span> couverts.</h2>
      <p class="v4-section-intro">
        Toutes les listes publiques FINMA sont récupérées, normalisées et fusionnées sous un schéma commun avec un champ <code class="mono" style="background: var(--color-bg-alt); padding: 2px 6px; border-radius: 4px;">entity_type</code> pour distinguer.
      </p>

      <div class="ds-table-wrap">
        <table class="ds-table">
          <thead>
            <tr><th>Type d'entité</th><th>Liste FINMA correspondante</th></tr>
          </thead>
          <tbody>
            <tr><td><strong>Banques</strong></td><td class="dim">Licences bancaires complètes + cantonales + privées</td></tr>
            <tr><td><strong>Assurances</strong></td><td class="dim">Vie + non-vie + réassurance + santé</td></tr>
            <tr><td><strong>PSP / Fintech</strong></td><td class="dim">Institutions de paiement, e-money, licence fintech</td></tr>
            <tr><td><strong>Gestionnaires d'actifs collectifs</strong></td><td class="dim">Fund managers sous LPCC/CISA</td></tr>
            <tr><td><strong>Gestionnaires d'actifs individuels</strong></td><td class="dim">Autorisés LEFin/FinIA</td></tr>
            <tr><td><strong>Maisons de titres</strong></td><td class="dim">Brokers, market makers</td></tr>
            <tr><td><strong>Représentants de fonds</strong></td><td class="dim">Distribution en CH de fonds étrangers</td></tr>
            <tr><td><strong>Membres SRO</strong></td><td class="dim">Intermédiaires financiers directement assujettis (DSFI)</td></tr>
            <tr><td><strong>Organismes de surveillance</strong></td><td class="dim">Bodies superviseurs FINSA</td></tr>
            <tr><td><strong>Intermédiaires d'assurance</strong></td><td class="dim">Courtiers &amp; agents enregistrés FINMA</td></tr>
          </tbody>
        </table>
      </div>
    </section>

    <section class="ds-section reveal-v4">
      <div class="v4-section-eyebrow">
        <strong>Schéma</strong>
        <span class="sep">/</span>
        <span>Champs communs aux 10 listes</span>
      </div>
      <h2 class="v4-section-h2">Schéma <span class="serif">unifié</span> sur les 10 listes.</h2>
      <p class="v4-section-intro">
        Tous les enregistrements partagent les mêmes champs. Vous pouvez filtrer par <code class="mono" style="background: var(--color-bg-alt); padding: 2px 6px; border-radius: 4px;">entity_type</code> ou interroger toutes les institutions d'un seul coup.
      </p>

      <div class="ds-table-wrap">
        <table class="ds-table">
          <thead>
            <tr><th>Champ</th><th>Type</th><th>Exemple</th></tr>
          </thead>
          <tbody>
            <tr><td class="mono">entity_type</td><td class="dim">enum (10 valeurs)</td><td class="mono">bank</td></tr>
            <tr><td class="mono">name</td><td class="dim">string</td><td>UBS Switzerland AG</td></tr>
            <tr><td class="mono">uid</td><td class="dim">string (CHE format)</td><td class="mono">CHE-101.329.561</td></tr>
            <tr><td class="mono">lei</td><td class="dim">string (20 chars)</td><td class="mono">506700LOLO53LDMTHY00</td></tr>
            <tr><td class="mono">licence_type</td><td class="dim">string</td><td>fintech licence</td></tr>
            <tr><td class="mono">licence_date</td><td class="dim">string (ISO)</td><td class="mono">2019-08-27</td></tr>
            <tr><td class="mono">status</td><td class="dim">string</td><td class="mono">active</td></tr>
            <tr><td class="mono">canton</td><td class="dim">string (2 lettres)</td><td class="mono">ZH</td></tr>
            <tr><td class="mono">address</td><td class="dim">string</td><td>Bahnhofstrasse 45, 8001 Zürich</td></tr>
            <tr><td class="mono">source_list</td><td class="dim">string</td><td class="mono">finma-banks</td></tr>
          </tbody>
        </table>
      </div>
    </section>

    <section class="ds-section reveal-v4">
      <div class="v4-section-eyebrow">
        <strong>Démo live</strong>
        <span class="sep">/</span>
        <span>Sans inscription</span>
      </div>
      <h2 class="v4-section-h2">Essayez <span class="serif">en vrai</span>.</h2>
      <p class="v4-section-intro">Cherchez une institution suisse et voyez immédiatement son type FINMA, son UID et son LEI.</p>
      <FinmaLookup />
    </section>

    <div class="ds-sample reveal-v4">
      <h3>Échantillon gratuit — 200 entités sur les 10 types</h3>
      <p>Aperçu équilibré (20 par type d'entité) pour valider le format. Toutes les colonnes sont présentes.</p>
      <a href="/samples/finma-sample.csv" download class="ds-sample-dl">
        <svg viewBox="0 0 14 14" fill="none"><path d="M7 1v9M3 7l4 4 4-4M2 13h10" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
        Télécharger finma-sample.csv
      </a>
    </div>

    <section class="ds-section reveal-v4">
      <div class="v4-section-eyebrow">
        <strong>Cas d'usage</strong>
        <span class="sep">/</span>
        <span>4 profils types</span>
      </div>
      <h2 class="v4-section-h2">À <span class="serif">qui</span> ça s'adresse.</h2>
      <div class="ds-audience-grid">
        <div class="ds-audience-item">
          <strong>Compliance officers FinTech &amp; banques</strong>
          <span>Vérification quotidienne des contreparties, due diligence KYC, screening anti-blanchiment.</span>
        </div>
        <div class="ds-audience-item">
          <strong>Plateformes B2B (paiement, lending)</strong>
          <span>Onboarding automatisé : vérifier qu'un partenaire est bien régulé FINMA en un appel API.</span>
        </div>
        <div class="ds-audience-item">
          <strong>Cabinets d'avocats financiers</strong>
          <span>Recherche d'entités, due diligence accélérée, audit des autorisations FINMA dans le temps.</span>
        </div>
        <div class="ds-audience-item">
          <strong>Régulateurs &amp; chercheurs</strong>
          <span>Time-series sur l'évolution du paysage financier suisse, études comparatives par canton.</span>
        </div>
      </div>
    </section>

    <div class="ds-cta" id="acheter">
      <form method="POST" action="/api/checkout/start" class="ds-cta-form">
        <input type="hidden" name="dataset_ids" value="finma" />
        <button type="submit" class="v4-btn v4-btn-primary v4-btn-cta">
          Acheter FINMA Registry — 299 CHF
          <span class="arrow">→</span>
        </button>
      </form>
      <p class="ds-cta-sub">Paiement sécurisé Stripe · Téléchargement immédiat par email · Remboursement 14 jours sans condition</p>
      <p class="ds-cta-alt">Ou prenez le <a href="/bundle">bundle complet (TARES + Classifications + FINMA) à 797 CHF</a> — économie 200 CHF (20 %).</p>
    </div>
  </div>
</section>
</BaseLayout>
