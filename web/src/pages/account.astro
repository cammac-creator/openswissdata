---
import BaseLayout from "../layouts/BaseLayout.astro";
---
<BaseLayout title="Espace client — openswissdata" noindex={true} monolingual={true}>
<div class="bg-grid"></div>

<section class="v4-hero ds-page">
  <div class="container-v4">
    <nav class="ds-breadcrumb">
      <a href="/">accueil</a>
      <span class="sep">·</span>
      <span class="current">Espace client</span>
    </nav>

    <div id="banner" class="account-banner hidden" role="status" aria-live="polite"></div>

    <!-- Login view -->
    <div id="login-view" class="hidden account-view">
      <div class="v4-eyebrow">
        <span>Espace client</span>
        <span style="opacity:.4">·</span>
        <span>connexion par lien magique</span>
      </div>
      <h1 class="v4-h1">Bienvenue.</h1>
      <p class="v4-lede">
        Entrez votre adresse email — nous vous enverrons un lien de connexion valable <strong>15 minutes</strong>. Pas de mot de passe à retenir.
      </p>

      <form id="login-form" class="account-form">
        <label for="login-email" class="sr-only">Adresse email</label>
        <input
          id="login-email"
          type="email"
          name="email"
          required
          autocomplete="email"
          placeholder="vous@entreprise.com"
        />
        <button type="submit" class="v4-btn v4-btn-primary">
          Recevoir le lien <span class="arrow">→</span>
        </button>
      </form>
      <p id="login-msg" class="account-msg"></p>

      <div class="account-onboarding">
        <h3>Comment ça marche</h3>
        <ol>
          <li><strong>Pas encore client ?</strong> Choisissez vos datasets sur <a href="/bundle">la page bundle</a> ou les pages <a href="/datasets/tares">TARES</a> · <a href="/datasets/classifications">Classifications</a> · <a href="/datasets/finma">FINMA</a>.</li>
          <li><strong>Achat sécurisé</strong> via Stripe (cartes, Apple Pay, Google Pay).</li>
          <li><strong>Réception immédiate</strong> d'un email avec un lien de téléchargement direct (ZIP signé Ed25519).</li>
          <li><strong>Accès permanent</strong> ici via le lien de connexion ci-dessus, à tout moment pendant les 360 jours d'updates inclus.</li>
        </ol>
      </div>
    </div>

    <!-- Dashboard view -->
    <div id="dashboard-view" class="hidden account-view">
      <div class="account-header">
        <div>
          <div class="v4-eyebrow">
            <span>Espace client</span>
            <span style="opacity:.4">·</span>
            <span id="dashboard-email"></span>
          </div>
          <h1 class="v4-h1" style="font-size: clamp(28px, 3vw, 40px);">Mes datasets</h1>
        </div>
        <button id="logout-btn" class="v4-btn v4-btn-secondary" style="font-size: 13px; padding: 10px 16px;">Se déconnecter</button>
      </div>
      <ul id="datasets-list" class="account-datasets-list"></ul>
      <p id="empty-state" class="hidden account-empty">
        Vous n'avez pas encore de dataset. <a href="/bundle">Voir le bundle complet — 797 CHF</a>.
      </p>
    </div>

    <div id="loading-view" class="account-loading">Chargement…</div>
  </div>
</section>

<style>
  .account-view { max-width: 720px; margin: 0 auto; padding: 24px 0; }
  .account-banner { padding: 14px 18px; border-radius: 10px; font-size: 14px; margin: 24px auto; max-width: 720px; }
  .account-banner.success { background: var(--green-soft); border: 1px solid var(--green); color: var(--green); }
  .account-banner.warn { background: var(--amber-soft); border: 1px solid var(--amber); color: var(--amber); }
  .account-banner.error { background: var(--accent-soft); border: 1px solid var(--accent); color: var(--accent); }

  .account-form { display: flex; flex-direction: column; gap: 12px; max-width: 460px; margin-bottom: 16px; }
  .account-form input {
    padding: 12px 14px;
    border: 1px solid var(--line-strong);
    border-radius: 8px;
    font-size: 15px;
    font-family: var(--font-sans);
    background: var(--bg-card);
    transition: border-color .15s, box-shadow .15s;
  }
  .account-form input:focus {
    outline: none;
    border-color: var(--ink);
    box-shadow: 0 0 0 3px rgba(10,10,12,.08);
  }
  .account-msg { font-size: 13px; color: var(--ink-mute); margin: 14px 0 0; }
  .account-msg.ok { color: var(--green); }
  .account-msg.err { color: var(--accent); }

  .account-onboarding {
    margin-top: 48px;
    padding: 24px 28px;
    background: var(--bg-card);
    border: 1px solid var(--line);
    border-radius: 12px;
  }
  .account-onboarding h3 {
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: .08em;
    text-transform: uppercase;
    color: var(--ink-mute);
    margin: 0 0 16px;
    font-weight: 500;
    padding-bottom: 12px;
    border-bottom: 1px solid var(--line);
  }
  .account-onboarding ol { margin: 0; padding-left: 22px; }
  .account-onboarding li { font-size: 14px; color: var(--ink-soft); line-height: 1.65; margin-bottom: 8px; }
  .account-onboarding a { color: var(--accent); text-decoration: none; border-bottom: 1px solid rgba(220,31,45,.25); }
  .account-onboarding a:hover { border-bottom-color: var(--accent); }

  .account-header {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 16px;
    flex-wrap: wrap;
    margin-bottom: 32px;
  }
  .account-datasets-list { list-style: none; padding: 0; margin: 0; display: flex; flex-direction: column; gap: 12px; }
  .account-empty { color: var(--ink-mute); font-size: 14px; margin-top: 28px; }
  .account-empty a { color: var(--accent); }
  .account-loading { color: var(--ink-mute); font-size: 14px; padding: 24px 0; }

  .ds-item {
    display: flex; align-items: center; justify-content: space-between; gap: 16px;
    padding: 18px 22px;
    background: var(--bg-card);
    border: 1px solid var(--line);
    border-radius: 10px;
    transition: border-color .15s;
  }
  .ds-item:hover { border-color: var(--line-strong); }
  .ds-item-info { min-width: 0; }
  .ds-item-name { font-weight: 600; color: var(--ink); font-size: 15px; }
  .ds-item-meta { font-size: 12px; color: var(--ink-mute); margin-top: 4px; font-family: var(--font-mono); }
  .ds-item-btn {
    flex-shrink: 0;
    background: var(--ink); color: var(--bg);
    padding: 10px 16px; border-radius: 8px; border: none;
    font-size: 13px; font-weight: 500; cursor: pointer;
    font-family: var(--font-sans);
    transition: background .15s;
  }
  .ds-item-btn:hover { background: #1a1a1d; }
  .ds-item-btn:disabled { opacity: .6; cursor: wait; }
</style>

  <script is:inline>
    (function () {
      const qs = new URLSearchParams(window.location.search);
      const authStatus = qs.get("auth");
      const checkoutStatus = qs.get("checkout");
      const banner = document.getElementById("banner");

      // Post-paiement Stripe — message en priorité (avant auth)
      if (checkoutStatus === "success") {
        banner.textContent = "✓ Paiement reçu. Vous allez recevoir un email de confirmation avec un lien de connexion sous 5 minutes. Vérifiez aussi vos spams si rien n'arrive.";
        banner.className = "account-banner success";
        banner.classList.remove("hidden");
      } else if (checkoutStatus === "cancelled") {
        banner.textContent = "Paiement annulé — aucun montant n'a été débité. Vous pouvez réessayer à tout moment.";
        banner.className = "account-banner warn";
        banner.classList.remove("hidden");
      } else if (authStatus === "ok") {
        banner.textContent = "Connexion réussie.";
        banner.className = "account-banner success";
        banner.classList.remove("hidden");
      } else if (authStatus === "invalid") {
        banner.textContent = "Ce lien de connexion n'est pas valide. Veuillez en demander un nouveau.";
        banner.className = "account-banner error";
        banner.classList.remove("hidden");
      } else if (authStatus === "expired") {
        banner.textContent = "Ce lien de connexion a expiré. Veuillez en demander un nouveau.";
        banner.className = "account-banner warn";
        banner.classList.remove("hidden");
      }

      const loadingEl = document.getElementById("loading-view");
      const loginEl = document.getElementById("login-view");
      const dashEl = document.getElementById("dashboard-view");
      const listEl = document.getElementById("datasets-list");
      const emptyEl = document.getElementById("empty-state");
      const emailLabelEl = document.getElementById("dashboard-email");

      function showLogin() {
        loadingEl.classList.add("hidden");
        dashEl.classList.add("hidden");
        loginEl.classList.remove("hidden");
      }

      function showDashboard(customer, datasets) {
        loadingEl.classList.add("hidden");
        loginEl.classList.add("hidden");
        dashEl.classList.remove("hidden");
        emailLabelEl.textContent = customer ? customer.email : "";
        listEl.innerHTML = "";
        if (!datasets || datasets.length === 0) {
          emptyEl.classList.remove("hidden");
          return;
        }
        emptyEl.classList.add("hidden");
        for (const d of datasets) {
          const li = document.createElement("li");
          li.className = "ds-item";

          const infoDiv = document.createElement("div");
          infoDiv.className = "ds-item-info";
          const nameEl = document.createElement("div");
          nameEl.className = "ds-item-name";
          nameEl.textContent = d.name;
          const metaEl = document.createElement("div");
          metaEl.className = "ds-item-meta";
          const vers = d.current_version ? ("v" + d.current_version) : "aucune version disponible";
          let meta = vers;
          if (d.updates_until) {
            const until = new Date(d.updates_until).toLocaleDateString("fr-CH");
            meta += " · mises à jour jusqu'au " + until;
          }
          metaEl.textContent = meta;
          infoDiv.appendChild(nameEl);
          infoDiv.appendChild(metaEl);

          const btn = document.createElement("button");
          btn.className = "ds-item-btn";
          btn.textContent = "Télécharger";
          btn.setAttribute("data-id", d.id);
          btn.addEventListener("click", async function () {
            btn.disabled = true;
            btn.textContent = "Préparation…";
            try {
              const r = await fetch("/api/account/download-request", {
                method: "POST",
                credentials: "include",
                headers: { "content-type": "application/json" },
                body: JSON.stringify({ dataset_id: d.id }),
              });
              if (!r.ok) {
                const err = await r.json().catch(function () { return {}; });
                throw new Error(err.error || ("HTTP " + r.status));
              }
              const body = await r.json();
              window.location.href = body.download_url;
            } catch (e) {
              btn.disabled = false;
              btn.textContent = "Réessayer";
              alert("Échec du téléchargement : " + (e && e.message ? e.message : String(e)));
            }
          });

          li.appendChild(infoDiv);
          li.appendChild(btn);
          listEl.appendChild(li);
        }
      }

      async function load() {
        try {
          const meRes = await fetch("/api/account", { credentials: "include" });
          if (meRes.status === 401) { showLogin(); return; }
          if (!meRes.ok) throw new Error("HTTP " + meRes.status);
          const meBody = await meRes.json();
          const dsRes = await fetch("/api/account/datasets", { credentials: "include" });
          const dsBody = dsRes.ok ? await dsRes.json() : { datasets: [] };
          showDashboard(meBody.customer, dsBody.datasets);
        } catch (e) {
          loadingEl.textContent = "Impossible de charger votre espace client. Veuillez actualiser la page.";
        }
      }

      document.getElementById("login-form").addEventListener("submit", async function (e) {
        e.preventDefault();
        const fd = new FormData(e.target);
        const email = String(fd.get("email") || "").trim();
        if (!email) return;
        const msgEl = document.getElementById("login-msg");
        msgEl.textContent = "Envoi en cours…";
        try {
          const r = await fetch("/api/auth/magic-link", {
            method: "POST",
            credentials: "include",
            headers: { "content-type": "application/json" },
            body: JSON.stringify({ email: email }),
          });
          if (r.ok) {
            msgEl.textContent = "✓ Vérifiez votre boîte de réception — le lien est valable 15 minutes.";
            msgEl.className = "account-msg ok";
          } else {
            msgEl.textContent = "Une erreur est survenue. Veuillez réessayer.";
            msgEl.className = "account-msg err";
          }
        } catch (err) {
          msgEl.textContent = "Erreur réseau. Veuillez réessayer.";
          msgEl.className = "account-msg err";
        }
      });

      document.getElementById("logout-btn").addEventListener("click", async function () {
        await fetch("/api/auth/logout", { method: "POST", credentials: "include" });
        window.location.href = "/account";
      });

      load();
    })();
  </script>
</BaseLayout>
