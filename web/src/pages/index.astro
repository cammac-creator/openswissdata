---
import BaseLayout from "../layouts/BaseLayout.astro";
---
<BaseLayout title="openswissdata — The Swiss data your ETL wishes existed">
  <section class="max-w-5xl mx-auto px-6 py-24 text-center">
    <h1 class="text-5xl font-bold tracking-tight">
      The Swiss data your ETL wishes existed.
    </h1>
    <p class="mt-6 text-xl text-slate-600">
      Official Swiss government datasets — normalized, versioned, ready to load.
    </p>
    <div class="mt-10 flex justify-center gap-4">
      <a href="/bundle" class="px-6 py-3 rounded bg-indigo-600 text-white">View bundle</a>
      <a href="/datasets/tares" class="px-6 py-3 rounded border border-slate-300">Browse datasets</a>
    </div>
  </section>
</BaseLayout>
