---
import BaseLayout from "../layouts/BaseLayout.astro";
import HSLookup from "../components/HSLookup.astro";
import CodePlayground from "../components/CodePlayground.astro";
---
<BaseLayout
  title="openswissdata — Les données publiques suisses, enfin utilisables"
  description="Datasets officiels suisses normalisés en JSON, Parquet et SQL : tarif douanier TARES, classifications NOGA/NACE/ISIC, registre FINMA. Permission commerciale explicite des autorités."
>

<!-- ============ HERO ============ -->
<section class="hero" id="hero">
  <div class="spotlight" id="hero-spotlight"></div>
  <div class="grain-overlay"></div>
  <div class="container-wide">
    <div class="eyebrow reveal">
      <span class="eyebrow-dot"></span>
      Lancement printemps 2026 · Données officielles suisses
    </div>
    <h1 class="hero-title reveal" data-delay="1">
      Les données publiques suisses,<br>
      <span class="serif" style="color: var(--color-accent);">enfin utilisables.</span>
    </h1>
    <p class="lede reveal" data-delay="2">
      L'État suisse publie des données précieuses — douanes, classifications économiques, registres financiers.
      Mais elles sortent en PDF, formats désuets, encodages cassés.
      <strong>openswissdata</strong> les transforme en formats propres, prêts à brancher dans n'importe quel logiciel.
    </p>
    <div class="hero-cta reveal" data-delay="3">
      <a href="/bundle" class="btn btn-primary">
        Voir les datasets
        <svg class="btn-arrow" viewBox="0 0 16 16" fill="none"><path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/></svg>
      </a>
      <a href="#problem" class="btn btn-secondary">Comprendre le problème</a>
    </div>

    <div class="hero-illu reveal">
      <div class="hero-illu-grid"></div>
      <div class="data-flow">
        <div class="data-source">
          <div class="data-card data-card-bad" style="animation-delay: .2s;">
            <span class="data-card-tag">PDF</span>
            <span>Tarif douanier 2 400 pages</span>
          </div>
          <div class="data-card data-card-bad" style="animation-delay: .35s;">
            <span class="data-card-tag">XLS</span>
            <span>NOGA 2025 — encodage cassé</span>
          </div>
          <div class="data-card data-card-bad" style="animation-delay: .5s;">
            <span class="data-card-tag">HTML</span>
            <span>FINMA × 10 listes</span>
          </div>
        </div>
        <div class="data-pipe">
          <svg class="pipe-svg" viewBox="0 0 200 280" fill="none" preserveAspectRatio="none">
            <path d="M0 60 Q 100 60, 100 140 Q 100 220, 200 220" stroke="rgba(255,255,255,.15)" stroke-width="1" stroke-dasharray="4 4"/>
            <path d="M0 100 Q 100 100, 100 140 Q 100 180, 200 180" stroke="rgba(255,255,255,.15)" stroke-width="1" stroke-dasharray="4 4"/>
            <path d="M0 140 L 200 140" stroke="rgba(255,255,255,.15)" stroke-width="1" stroke-dasharray="4 4"/>
          </svg>
          <div class="pipe-core">openswissdata</div>
        </div>
        <div class="data-target">
          <div class="data-card data-card-good" style="animation-delay: .65s;">
            <span class="data-card-tag">JSON</span>
            <span>Propre · UTF-8 · validé</span>
          </div>
          <div class="data-card data-card-good" style="animation-delay: .8s;">
            <span class="data-card-tag">PARQUET</span>
            <span>Optimisé analytics</span>
          </div>
          <div class="data-card data-card-good" style="animation-delay: .95s;">
            <span class="data-card-tag">SQL</span>
            <span>Versionné · cross-walks</span>
          </div>
        </div>
      </div>
    </div>

    <div class="stats-row reveal">
      <div class="stat">
        <div class="stat-num"><span class="counter" data-count="7511">7 511</span></div>
        <div class="stat-label">Codes douaniers dans le dataset TARES</div>
      </div>
      <div class="stat">
        <div class="stat-num">~<span class="counter" data-count="40">40</span><span class="unit">h</span></div>
        <div class="stat-label">Économisées versus parsing manuel par vos équipes</div>
      </div>
      <div class="stat">
        <div class="stat-num"><span class="counter" data-count="3">3</span></div>
        <div class="stat-label">Standards de classifications avec cross-walks</div>
      </div>
      <div class="stat">
        <div class="stat-num">CH</div>
        <div class="stat-label">Hébergement Suisse-EU, conforme nFADP</div>
      </div>
    </div>
  </div>
</section>

<!-- ============ LIVE DEMO ============ -->
<section id="demo" class="demo-section">
  <div class="container-wide">
    <span class="section-tag reveal">démo · 30 secondes</span>
    <h2 class="section-title reveal" data-delay="1">
      Essayez <span class="serif">en vrai,</span> tout de suite.
    </h2>
    <p class="section-intro reveal" data-delay="2">
      Voici un échantillon de notre dataset TARES. Tapez n'importe quel produit (en français, allemand ou italien) ou un code HS à 8 chiffres. C'est exactement ce que vos équipes peuvent intégrer dans votre logiciel en cinq minutes.
    </p>
    <div class="reveal" data-delay="2">
      <HSLookup />
    </div>

    <div class="demo-divider reveal">
      <span>ou intégrez l'API directement dans votre code</span>
    </div>

    <div class="reveal" data-delay="1">
      <CodePlayground />
    </div>
  </div>
</section>

<!-- ============ PULL QUOTE 1 ============ -->
<section class="pull-quote-section">
  <div class="container-tight">
    <p class="pull-quote reveal">
      « Les bonnes données ne se trouvent pas. Elles se construisent. »
    </p>
    <div class="pull-quote-author reveal" data-delay="1">Manifeste — openswissdata</div>
  </div>
</section>

<!-- ============ STORY / PROBLEM ============ -->
<section id="problem" class="story">
  <div class="container-wide">
    <span class="section-tag reveal">01 — le problème</span>
    <h2 class="section-title reveal" data-delay="1">
      Les données existent.<br>
      <span class="serif">Personne ne peut les utiliser.</span>
    </h2>
    <p class="section-intro reveal" data-delay="2">
      L'État suisse publie des centaines de jeux de données ouverts. C'est une excellente nouvelle.
      Le problème : ils sont publiés tels qu'ils existent en interne — souvent en PDF, parfois en Excel avec des cellules fusionnées,
      souvent dans des encodages des années 90. Pour une équipe technique, importer ces données dans un produit prend des semaines.
    </p>

    <div class="story-grid">
      <div class="frustration-illu reveal">
        <div class="messy-data">
          <div class="messy-doc messy-doc-1">
            <div class="messy-lines"></div>
            <div class="messy-lines"></div>
            <div class="messy-lines"></div>
            <div class="messy-lines"></div>
          </div>
          <div class="messy-doc messy-doc-2">
            <div class="messy-lines"></div>
            <div class="messy-lines"></div>
            <div class="messy-lines"></div>
            <div class="messy-lines"></div>
          </div>
          <div class="messy-doc messy-doc-3">
            <div class="messy-lines"></div>
            <div class="messy-lines"></div>
            <div class="messy-lines"></div>
            <div class="messy-lines"></div>
          </div>
        </div>
      </div>

      <div class="scenario reveal" data-delay="1">
        <span class="scenario-label">SCÉNARIO RÉEL</span>
        <p class="hero-quote">
          « On a essayé d'intégrer le tarif douanier suisse dans notre ERP. Ça nous a pris six semaines, et on n'est toujours pas sûrs que les chapitres soient à jour. »
        </p>
        <p class="scenario-text">
          C'est ce qu'on entend chez les éditeurs de logiciels logistiques, les compliance officers, les data teams des assureurs.
          Les données officielles existent — mais entre exister et être utilisables, il y a un gouffre.
        </p>
        <p class="scenario-text">
          Ce gouffre, c'est : décoder du PDF, normaliser des encodages cassés, écrire des cross-walks entre standards (NOGA suisse vs NACE européen vs ISIC mondial),
          versionner pour suivre les mises à jour, vérifier que rien n'a cassé entre deux releases.
        </p>
      </div>
    </div>
  </div>
</section>

<!-- ============ SOLUTION ============ -->
<section id="solution" class="explain">
  <div class="container-wide">
    <span class="section-tag reveal">02 — notre solution, expliquée à tout âge</span>
    <h2 class="section-title reveal" data-delay="1">
      <span class="serif">Une seule chose,</span> bien faite.
    </h2>
    <p class="section-intro reveal" data-delay="2">
      On télécharge les données depuis les sources officielles. On les nettoie, on les normalise, on les enrichit avec des passerelles entre standards.
      On les livre en formats modernes, avec une licence claire et un suivi des mises à jour. Voilà l'idée. Le détail dépend de qui pose la question.
    </p>

    <div class="explain-card reveal" data-delay="1">
      <div class="age-tabs">
        <button class="age-tab active" data-age="kid">Pour un enfant</button>
        <button class="age-tab" data-age="parent">Pour mes parents</button>
        <button class="age-tab" data-age="pro">Pour un pro de la tech</button>
        <button class="age-tab" data-age="exec">Pour un dirigeant</button>
      </div>

      <div class="age-content active" data-age="kid">
        <h3>Imagine une grande bibliothèque qui range mal ses livres.</h3>
        <p>
          La Suisse a une bibliothèque géante de livres très importants : sur les marchandises qui passent les douanes, sur les métiers, sur les banques.
          Mais les livres sont rangés n'importe comment. Certains sont écrits dans une langue bizarre. D'autres ont les pages collées.
        </p>
        <p>
          Notre travail, c'est d'aller chercher ces livres, de les nettoyer, de les recopier proprement, et de les ranger dans un ordre simple.
          Comme ça, les gens qui en ont besoin peuvent les lire en deux minutes au lieu de deux mois.
        </p>
      </div>

      <div class="age-content" data-age="parent">
        <h3>L'État publie des chiffres importants. Mal présentés.</h3>
        <p>
          Quand l'administration publie des données — par exemple la liste de tous les codes douaniers, ou la classification officielle des secteurs d'activité —
          elle les met en ligne dans des formats vieux et compliqués (souvent en PDF de plusieurs centaines de pages).
        </p>
        <p>
          Les entreprises qui ont besoin de ces données — des banques, des assureurs, des éditeurs de logiciels — perdent des semaines à essayer de les exploiter.
          Notre service fait ce travail une seule fois, proprement, et le revend aux entreprises qui en ont besoin. C'est moins cher pour elles, et de bien meilleure qualité.
        </p>
      </div>

      <div class="age-content" data-age="pro">
        <h3>Datasets officiels suisses normalisés en JSON / Parquet / SQL.</h3>
        <p>
          On parse les sources publiques (TARES, NOGA, NACE, FINMA Registry), on normalise en UTF-8, on enrichit avec des cross-walks multi-standards,
          on versionne sémantiquement (semver), on signe les releases. Livraison via R2 signed URLs, accès one-shot ou abonnement updates yearly.
        </p>
        <p>
          Backend Hono + SQLite, paiements Stripe, hébergement Railway EU/Frankfurt. Webhooks Stripe pour provisionnement automatique. Compliance nFADP & permissions commerciales explicites des autorités émettrices (BAZG ✓, BFS et FINMA en cours).
        </p>
      </div>

      <div class="age-content" data-age="exec">
        <h3>Réduire le coût d'intégration des données réglementaires suisses.</h3>
        <p>
          Vos équipes data passent du temps à faire de l'ETL sur des sources publiques mal formatées. Ce travail ne crée aucun avantage compétitif —
          il vous met juste au niveau zéro. openswissdata externalise ce coût pour le mutualiser entre tous nos clients.
        </p>
        <p>
          Pricing one-shot 299–399 CHF par dataset, abonnement updates 120–160 CHF/an. Bundle complet à 799 CHF.
          ROI positif dès la première semaine d'utilisation versus un effort interne. Permission commerciale explicite des autorités émettrices.
        </p>
      </div>
    </div>
  </div>
</section>

<!-- ============ HOW IT WORKS ============ -->
<section id="how" class="how-section">
  <div class="container-wide">
    <span class="section-tag reveal">le processus</span>
    <h2 class="section-title reveal" data-delay="1">
      Comment <span class="serif">on s'assure</span> que les données sont propres.
    </h2>
    <p class="section-intro reveal" data-delay="2">
      On répète ce cycle à chaque release. Pas de raccourcis : c'est ce qui garantit qu'une mise à jour BAZG ou BFS ne casse pas votre intégration.
    </p>

    <div class="steps-grid">
      <div class="step reveal">
        <div class="step-num">1</div>
        <div class="step-tag">Source</div>
        <h3 class="step-title">Téléchargement direct</h3>
        <p class="step-text">Récupération automatisée depuis xtares.admin.ch, BFS Ramon, FINMA. Vérification SHA-256 contre la version précédente pour détecter tout changement.</p>
      </div>
      <div class="step reveal" data-delay="1">
        <div class="step-num">2</div>
        <div class="step-tag">Parsing</div>
        <h3 class="step-title">Normalisation UTF-8</h3>
        <p class="step-text">Décodage des PDF, fusion des cellules Excel, conversion vers UTF-8 propre. Validation contre un schéma JSON Schema strict — toute incohérence stoppe la release.</p>
      </div>
      <div class="step reveal" data-delay="2">
        <div class="step-num">3</div>
        <div class="step-tag">Enrichissement</div>
        <h3 class="step-title">Cross-walks &amp; index</h3>
        <p class="step-text">Génération des passerelles entre standards (NOGA ↔ NACE ↔ ISIC), des index de recherche full-text, et des fichiers compressés Parquet pour l'analytique.</p>
      </div>
      <div class="step reveal" data-delay="3">
        <div class="step-num">4</div>
        <div class="step-tag">Livraison</div>
        <h3 class="step-title">Release versionnée</h3>
        <p class="step-text">Tag semver, signature, upload sur R2 Frankfurt, notification email aux clients abonnés aux updates. Changelog public détaillant chaque modification.</p>
      </div>
    </div>
  </div>
</section>

<!-- ============ DATASETS ============ -->
<section id="datasets" class="datasets-section">
  <div class="container-wide">
    <span class="section-tag reveal">03 — ce qu'on livre</span>
    <h2 class="section-title reveal" data-delay="1">
      Trois datasets <span class="serif">qui valent leur poids en heures gagnées.</span>
    </h2>
    <p class="section-intro reveal" data-delay="2">
      Chaque dataset est livré en JSON, Parquet et SQL, avec un schéma documenté et un changelog versionné.
      Vous achetez la version actuelle (one-shot), ou vous vous abonnez aux mises à jour annuelles.
    </p>

    <div class="dataset-grid">
      <a href="/datasets/tares" class="dataset-card reveal">
        <div class="dataset-icon">
          <svg width="28" height="28" viewBox="0 0 28 28" fill="none">
            <rect x="4" y="6" width="20" height="16" rx="2" stroke="#0F1115" stroke-width="1.5"/>
            <path d="M4 11h20" stroke="#0F1115" stroke-width="1.5"/>
            <path d="M9 6V4M19 6V4" stroke="#0F1115" stroke-width="1.5" stroke-linecap="round"/>
            <circle cx="14" cy="16" r="2" fill="#DC1F2D"/>
          </svg>
        </div>
        <div class="dataset-meta">TARES · BAZG ✓ permission accordée</div>
        <h3>Tarif douanier suisse</h3>
        <p>
          L'intégralité du tarif douanier suisse normalisé : codes HS à 8 chiffres, taux, unités, restrictions, accords commerciaux.
          Trilingue DE/FR/IT. Mises à jour trimestrielles.
        </p>
        <div class="dataset-stats">
          <div class="dataset-stat">
            <span class="dataset-stat-num">~10K</span>
            <span class="dataset-stat-label">Codes</span>
          </div>
          <div class="dataset-stat">
            <span class="dataset-stat-num">3</span>
            <span class="dataset-stat-label">Langues</span>
          </div>
          <div class="dataset-stat">
            <span class="dataset-stat-num">299<span class="dataset-stat-unit"> CHF</span></span>
            <span class="dataset-stat-label">One-shot</span>
          </div>
        </div>
        <div class="dataset-cta">Voir le dataset →</div>
      </a>

      <a href="/datasets/classifications" class="dataset-card reveal" data-delay="1">
        <div class="dataset-icon">
          <svg width="28" height="28" viewBox="0 0 28 28" fill="none">
            <rect x="4" y="4" width="8" height="8" rx="1.5" stroke="#0F1115" stroke-width="1.5"/>
            <rect x="16" y="4" width="8" height="8" rx="1.5" stroke="#0F1115" stroke-width="1.5"/>
            <rect x="4" y="16" width="8" height="8" rx="1.5" stroke="#0F1115" stroke-width="1.5"/>
            <rect x="16" y="16" width="8" height="8" rx="1.5" stroke="#DC1F2D" stroke-width="1.5"/>
            <path d="M12 8h4M8 12v4M16 20h-4M20 16v-4" stroke="#0F1115" stroke-width="1.5" stroke-dasharray="2 2"/>
          </svg>
        </div>
        <div class="dataset-meta">NOGA + NACE + ISIC · BFS en attente</div>
        <h3>Classifications économiques</h3>
        <p>
          NOGA 2025 (suisse) + NACE Rev. 2.1 (européenne) + ISIC Rev. 4 (mondiale).
          Avec les passerelles bidirectionnelles entre les trois standards. Idéal pour reporting multi-juridictions.
        </p>
        <div class="dataset-stats">
          <div class="dataset-stat">
            <span class="dataset-stat-num">~3K</span>
            <span class="dataset-stat-label">Codes / standard</span>
          </div>
          <div class="dataset-stat">
            <span class="dataset-stat-num">3</span>
            <span class="dataset-stat-label">Standards</span>
          </div>
          <div class="dataset-stat">
            <span class="dataset-stat-num">399<span class="dataset-stat-unit"> CHF</span></span>
            <span class="dataset-stat-label">One-shot</span>
          </div>
        </div>
        <div class="dataset-cta">Voir le dataset →</div>
      </a>

      <a href="/datasets/finma" class="dataset-card reveal" data-delay="2">
        <div class="dataset-icon">
          <svg width="28" height="28" viewBox="0 0 28 28" fill="none">
            <path d="M14 4L24 9V15C24 19.5 19.5 23 14 24C8.5 23 4 19.5 4 15V9L14 4Z" stroke="#0F1115" stroke-width="1.5" stroke-linejoin="round"/>
            <circle cx="14" cy="14" r="3" fill="#DC1F2D"/>
          </svg>
        </div>
        <div class="dataset-meta">FINMA Registry · FINMA en attente</div>
        <h3>Registre FINMA unifié</h3>
        <p>
          Les 10 listes publiques d'autorisations FINMA (banques, assureurs, gestionnaires, etc.) consolidées en un seul registre indexé.
          Plus besoin de scraper 10 pages web différentes.
        </p>
        <div class="dataset-stats">
          <div class="dataset-stat">
            <span class="dataset-stat-num">~5K</span>
            <span class="dataset-stat-label">Entités</span>
          </div>
          <div class="dataset-stat">
            <span class="dataset-stat-num">10</span>
            <span class="dataset-stat-label">Catégories</span>
          </div>
          <div class="dataset-stat">
            <span class="dataset-stat-num">299<span class="dataset-stat-unit"> CHF</span></span>
            <span class="dataset-stat-label">One-shot</span>
          </div>
        </div>
        <div class="dataset-cta">Voir le dataset →</div>
      </a>
    </div>
  </div>
</section>

<!-- ============ COMPARISON ============ -->
