---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getCollection } from "astro:content";

const posts = (await getCollection("blog"))
  .sort((a, b) => b.data.publishedAt.getTime() - a.data.publishedAt.getTime());

const datasetLabels: Record<string, string> = {
  tares: "TARES",
  classifications: "Classifications",
  finma: "FINMA",
  all: "Bundle",
};
const datasetCovers: Record<string, string> = {
  tares: "/og-tares.png",
  classifications: "/og-classifications.png",
  finma: "/og-finma.png",
  all: "/og-default.png",
};
---
<BaseLayout
  title="Blog — openswissdata"
  description="Notes techniques et guides d'intégration pour les datasets fédéraux suisses (TARES, Classifications, FINMA)."
  monolingual={true}
>
<div class="bg-grid"></div>

<section class="v4-hero ds-page">
  <div class="container-v4">
    <nav class="ds-breadcrumb">
      <a href="/">accueil</a>
      <span class="sep">·</span>
      <span class="current">Blog</span>
    </nav>

    <div class="v4-eyebrow">
      <span>Notes techniques</span>
      <span style="opacity:.4">·</span>
      <span>Pour data engineers, compliance, intégrateurs ERP</span>
    </div>
    <h1 class="v4-h1">Blog.</h1>
    <p class="v4-lede">
      Guides d'intégration et retours d'expérience sur les datasets fédéraux suisses. Niveau technique : data engineer, compliance officer, intégrateur ERP.
    </p>

    <ul class="blog-list">
      {posts.map(post => {
        const cover = post.data.dataset ? datasetCovers[post.data.dataset] : null;
        return (
          <li class="blog-card">
            <a href={`/blog/${post.id}`} class="blog-card-link">
              <div class="blog-card-body">
                <div class="blog-card-meta">
                  <time datetime={post.data.publishedAt.toISOString()}>{post.data.publishedAt.toISOString().slice(0, 10)}</time>
                  {post.data.dataset && (
                    <>
                      <span style="opacity:.4">·</span>
                      <span class="blog-card-dataset">{datasetLabels[post.data.dataset] ?? post.data.dataset}</span>
                    </>
                  )}
                </div>
                <h2 class="blog-card-title">{post.data.title}</h2>
                <p class="blog-card-desc">{post.data.description}</p>
                <span class="blog-card-cta">Lire <span class="arrow">→</span></span>
              </div>
              {cover && (
                <div class="blog-card-cover" aria-hidden="true">
                  <img src={cover} alt="" loading="lazy" />
                </div>
              )}
            </a>
          </li>
        );
      })}
    </ul>
  </div>
</section>
</BaseLayout>

<style>
  .blog-list { list-style: none; padding: 0; margin: 32px 0 0; display: flex; flex-direction: column; gap: 18px; }
  .blog-card {
    background: var(--bg-card);
    border: 1px solid var(--line);
    border-radius: 14px;
    overflow: hidden;
    transition: border-color .2s var(--ease-out), transform .2s var(--ease-out), box-shadow .2s var(--ease-out);
  }
  .blog-card:hover {
    border-color: var(--line-strong);
    transform: translateY(-2px);
    box-shadow: 0 12px 28px -16px rgba(10,10,12,.18);
  }
  .blog-card-link {
    display: grid;
    grid-template-columns: 1fr 280px;
    align-items: stretch;
    color: inherit;
    text-decoration: none;
    min-height: 156px;
  }
  .blog-card-body {
    padding: 26px 28px;
    display: flex;
    flex-direction: column;
    justify-content: center;
  }
  .blog-card-meta {
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: .04em;
    color: var(--ink-mute);
    margin-bottom: 10px;
    display: flex;
    gap: 10px;
    align-items: center;
  }
  .blog-card-dataset { color: var(--accent); font-weight: 600; text-transform: uppercase; }
  .blog-card-title {
    font-size: clamp(20px, 2.2vw, 24px);
    font-weight: 700;
    letter-spacing: -.02em;
    line-height: 1.25;
    color: var(--ink);
    margin: 0 0 10px;
    transition: color .15s;
  }
  .blog-card:hover .blog-card-title { color: var(--accent); }
  .blog-card-desc {
    font-size: 14px;
    line-height: 1.55;
    color: var(--ink-soft);
    margin: 0 0 14px;
  }
  .blog-card-cta {
    font-family: var(--font-mono);
    font-size: 12px;
    color: var(--accent);
    font-weight: 600;
  }
  .blog-card-cta .arrow { display: inline-block; transition: transform .15s; }
  .blog-card:hover .blog-card-cta .arrow { transform: translateX(3px); }

  /* Cover thumbnail — dataset banner shown on the right of each card */
  .blog-card-cover {
    position: relative;
    overflow: hidden;
    background: var(--bg-soft);
    border-left: 1px solid var(--line);
  }
  .blog-card-cover img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: right center;
    transition: transform .4s var(--ease-out);
  }
  .blog-card:hover .blog-card-cover img { transform: scale(1.03); }
  .blog-card-cover::after {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(90deg, var(--bg-card) 0%, transparent 12%);
    pointer-events: none;
  }

  @media (max-width: 800px) {
    .blog-card-link { grid-template-columns: 1fr; }
    .blog-card-cover {
      order: -1;
      height: 140px;
      border-left: none;
      border-bottom: 1px solid var(--line);
    }
    .blog-card-cover::after {
      background: linear-gradient(180deg, transparent 60%, var(--bg-card) 100%);
    }
  }
</style>
