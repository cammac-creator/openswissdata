---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getCollection } from "astro:content";

const posts = (await getCollection("blog"))
  .sort((a, b) => b.data.publishedAt.getTime() - a.data.publishedAt.getTime());
---
<BaseLayout
  title="Blog — openswissdata.com"
  description="Technical notes and integration guides for Swiss government datasets."
>
  <section class="max-w-3xl mx-auto px-6 py-16">
    <nav class="text-sm text-slate-500 mb-4">
      <a href="/" class="hover:underline">Home</a> · <span>Blog</span>
    </nav>
    <h1 class="text-4xl font-bold mb-2">Blog</h1>
    <p class="text-lg text-slate-600 mb-10">Integration guides and technical notes on Swiss government data.</p>
    <ul class="space-y-6">
      {posts.map(post => (
        <li class="border-b border-slate-200 pb-6">
          <a href={`/blog/${post.id}`} class="block group">
            <h2 class="text-2xl font-semibold text-slate-900 group-hover:text-indigo-600 transition-colors">{post.data.title}</h2>
            <p class="text-sm text-slate-500 mt-1">
              {post.data.publishedAt.toISOString().slice(0, 10)}
              {post.data.dataset && ` · ${post.data.dataset}`}
            </p>
            <p class="text-slate-700 mt-2">{post.data.description}</p>
          </a>
        </li>
      ))}
    </ul>
  </section>
</BaseLayout>
