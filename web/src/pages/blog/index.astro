---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getCollection } from "astro:content";

const posts = (await getCollection("blog"))
  .sort((a, b) => b.data.publishedAt.getTime() - a.data.publishedAt.getTime());

const datasetLabels: Record<string, string> = {
  tares: "TARES",
  classifications: "Classifications",
  finma: "FINMA",
  all: "Bundle",
};
---
<BaseLayout
  title="Blog — openswissdata"
  description="Notes techniques et guides d'intégration pour les datasets fédéraux suisses (TARES, Classifications, FINMA)."
  monolingual={true}
>
<div class="bg-grid"></div>

<section class="v4-hero ds-page">
  <div class="container-v4">
    <nav class="ds-breadcrumb">
      <a href="/">accueil</a>
      <span class="sep">·</span>
      <span class="current">Blog</span>
    </nav>

    <div class="v4-eyebrow">
      <span>Notes techniques</span>
      <span style="opacity:.4">·</span>
      <span>Pour data engineers, compliance, intégrateurs ERP</span>
    </div>
    <h1 class="v4-h1">Blog.</h1>
    <p class="v4-lede">
      Guides d'intégration et retours d'expérience sur les datasets fédéraux suisses. Niveau technique : data engineer, compliance officer, intégrateur ERP.
    </p>

    <ul class="blog-list">
      {posts.map(post => (
        <li class="blog-card">
          <a href={`/blog/${post.id}`} class="blog-card-link">
            <div class="blog-card-meta">
              <time datetime={post.data.publishedAt.toISOString()}>{post.data.publishedAt.toISOString().slice(0, 10)}</time>
              {post.data.dataset && (
                <>
                  <span style="opacity:.4">·</span>
                  <span class="blog-card-dataset">{datasetLabels[post.data.dataset] ?? post.data.dataset}</span>
                </>
              )}
            </div>
            <h2 class="blog-card-title">{post.data.title}</h2>
            <p class="blog-card-desc">{post.data.description}</p>
            <span class="blog-card-cta">Lire <span class="arrow">→</span></span>
          </a>
        </li>
      ))}
    </ul>
  </div>
</section>
</BaseLayout>

<style>
  .blog-list { list-style: none; padding: 0; margin: 32px 0 0; display: flex; flex-direction: column; gap: 16px; }
  .blog-card {
    background: var(--bg-card);
    border: 1px solid var(--line);
    border-radius: 12px;
    transition: border-color .15s, transform .15s;
  }
  .blog-card:hover { border-color: var(--line-strong); transform: translateY(-1px); }
  .blog-card-link { display: block; padding: 24px 28px; color: inherit; text-decoration: none; }
  .blog-card-meta {
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: .04em;
    color: var(--ink-mute);
    margin-bottom: 12px;
    display: flex;
    gap: 10px;
    align-items: center;
  }
  .blog-card-dataset { color: var(--accent); font-weight: 600; text-transform: uppercase; }
  .blog-card-title {
    font-size: clamp(20px, 2.2vw, 24px);
    font-weight: 700;
    letter-spacing: -.02em;
    line-height: 1.25;
    color: var(--ink);
    margin: 0 0 10px;
    transition: color .15s;
  }
  .blog-card:hover .blog-card-title { color: var(--accent); }
  .blog-card-desc {
    font-size: 14px;
    line-height: 1.55;
    color: var(--ink-soft);
    margin: 0 0 14px;
  }
  .blog-card-cta {
    font-family: var(--font-mono);
    font-size: 12px;
    color: var(--accent);
    font-weight: 600;
  }
  .blog-card-cta .arrow { display: inline-block; transition: transform .15s; }
  .blog-card:hover .blog-card-cta .arrow { transform: translateX(3px); }
</style>
