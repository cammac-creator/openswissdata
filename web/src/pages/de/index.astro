---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Terminal from "../../components/Terminal.astro";
import InstallBar from "../../components/InstallBar.astro";
import TrustStrip from "../../components/TrustStrip.astro";
import PersonaTile from "../../components/PersonaTile.astro";
import Fiche from "../../components/Fiche.astro";
import Step from "../../components/Step.astro";
import Quote from "../../components/Quote.astro";
---
<BaseLayout
  title="openswissdata — Schweizer Bundesdaten, normalisiert"
  description="Offizielle Schweizer Datasets normalisiert (TARES, NOGA/NACE/ISIC, FINMA Registry) in JSON, Parquet und SQL. BAZG-Bewilligung erteilt. Versioniert, Ed25519-signiert, einsatzbereit."
>

<div class="bg-grid"></div>

<!-- ========== HERO ========== -->
<section class="v4-hero">
  <div class="container-v4">
    <div class="v4-hero-grid">
      <div>
        <div class="v4-eyebrow reveal-v4">
          <span>Offizielle Schweizer Daten</span>
          <span style="opacity:.4">·</span>
          <span class="check">BAZG-Bewilligung</span>
        </div>

        <h1 class="v4-h1 reveal-v4" data-delay="1">
          Schweizer Bundesdaten,<br>
          <span class="accent">normalisiert.</span>
        </h1>

        <p class="v4-lede reveal-v4" data-delay="2">
          TARES, NOGA·NACE·ISIC, FINMA Registry — extrahiert aus den autoritativen Bundesquellen, geliefert <strong>normalisiert, versioniert und Ed25519-signiert</strong>. Für Ihre Pipelines, Audits und ERP-Integrationen.
        </p>

        <div class="v4-spec-row reveal-v4" data-delay="3">
          <div class="v4-spec">
            <div class="v4-spec-label">Datasets</div>
            <div class="v4-spec-value">3 + Bundle</div>
          </div>
          <div class="v4-spec">
            <div class="v4-spec-label">Codes</div>
            <div class="v4-spec-value" data-count="12800">~12 800</div>
          </div>
          <div class="v4-spec">
            <div class="v4-spec-label">Formate</div>
            <div class="v4-spec-value">Parquet · JSON · SQL</div>
          </div>
        </div>

        <div class="v4-cta-row reveal-v4" data-delay="4">
          <a href="#datasets" class="v4-btn v4-btn-primary">Datasets ansehen <span class="arrow">→</span></a>
          <InstallBar command="npx @osd/cli pull tares" />
        </div>

        <div class="v4-permission-line reveal-v4" data-delay="5">
          <span><strong>Quellen:</strong> BAZG · BFS · FINMA</span>
          <span style="opacity:.4">·</span>
          <span class="ok">Bewilligung erteilt 2026-04-21</span>
          <span style="opacity:.4">·</span>
          <span><strong>Gerichtsstand:</strong> Bern</span>
        </div>

        <div class="v4-hero-chain reveal-v4" data-delay="5" aria-label="Kryptografische Provenienzkette">
          <div class="v4-chain-node" data-step="1"><span class="dot"></span><strong>BAZG</strong></div>
          <div class="v4-chain-link" data-step="1"></div>
          <div class="v4-chain-node" data-step="2">SHA-256</div>
          <div class="v4-chain-link" data-step="2"></div>
          <div class="v4-chain-node" data-step="3">Ed25519</div>
          <div class="v4-chain-link" data-step="3"></div>
          <div class="v4-chain-node" data-step="4">RFC-3161</div>
          <div class="v4-chain-link" data-step="4"></div>
          <div class="v4-chain-node" data-step="5"><span class="dot"></span><strong>Verified</strong></div>
        </div>
      </div>

      <div class="reveal-v4" data-delay="2">
        <Terminal title="~/erp-integration — zsh" />
      </div>
    </div>
  </div>
</section>

<TrustStrip
  sources={["BAZG", "BFS", "FINMA"]}
  badges={["BAZG-Bewilligung · 2026-04-21", "Ed25519-signiertes Manifest", "RFC-3161 Zeitstempel"]}
