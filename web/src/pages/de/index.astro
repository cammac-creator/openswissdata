<!-- ========== HOW IT WORKS ========== -->
<section class="v4-how" id="how">
  <div class="container-v4">
    <div class="v4-section-eyebrow reveal-v4">
      <strong>So funktioniert es</strong>
      <span class="sep">/</span>
      <span>15 Minuten von der Zahlung in die Produktion</span>
