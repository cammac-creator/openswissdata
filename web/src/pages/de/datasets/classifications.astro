---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import ClassificationsLookup from "../../../components/ClassificationsLookup.astro";
import TrustStrip from "../../../components/TrustStrip.astro";
import ProductFaq from "../../../components/ProductFaq.astro";

const productJsonLd = {
  "@context": "https://schema.org",
  "@type": "Product",
  name: "Classifications NOGA + NACE + ISIC",
  description: "5 Wirtschaftsklassifikationen vereint: NOGA 2008/2025, NACE Rev 2/2.1, ISIC Rev 4. Bidirektionale Cross-Walks, 4 Sprachen. JSON / Parquet / SQL.",
  image: "https://www.openswissdata.com/og-classifications.png",
  url: "https://www.openswissdata.com/de/datasets/classifications",
  brand: { "@type": "Brand", name: "openswissdata" },
  category: "Reference data — economic activity classifications",
  offers: {
    "@type": "Offer",
    price: "399",
    priceCurrency: "CHF",
    availability: "https://schema.org/InStock",
    url: "https://www.openswissdata.com/de/datasets/classifications#kaufen",
    priceValidUntil: "2026-12-31",
    seller: { "@type": "Organization", name: "openswissdata" },
  },
};
---
<BaseLayout
  title="Wirtschaftsklassifikationen NOGA + NACE + ISIC | openswissdata"
  description="5 Wirtschaftsklassifikationen vereint: NOGA 2008/2025, NACE Rev 2/2.1, ISIC Rev 4. Bidirektionale Cross-Walks, 4 Sprachen. JSON / Parquet / SQL. 399 CHF einmalig."
  image="/og-classifications.png"
  productJsonLd={productJsonLd}
>
<div class="bg-grid"></div>

<section class="v4-hero ds-page">
  <div class="ds-hero-banner-bg" style="background-image:url('/og-classifications.png');" aria-hidden="true"></div>
  <div class="container-v4">
    <nav class="ds-breadcrumb">
      <a href="/de/">Startseite</a>
      <span class="sep">·</span>
      <a href="/de/bundle">Datasets</a>
      <span class="sep">·</span>
      <span class="current">Classifications</span>
    </nav>

    <div class="v4-hero-grid">
      <div>
        <div class="v4-eyebrow reveal-v4">
          <span>Classifications · 5 Standards</span>
          <span style="opacity:.4">·</span>
          <span>BFS · Bewilligung beantragt 2026-04-17</span>
        </div>

        <h1 class="v4-h1 reveal-v4" data-delay="1">
          NOGA, NACE, ISIC<br>
          <span class="accent">aufeinander abgestimmt.</span>
        </h1>

        <p class="v4-lede reveal-v4" data-delay="2">
          Fünf vereinte Nomenklaturen (NOGA 2008, NOGA 2025, NACE Rev 2, NACE Rev 2.1, ISIC Rev 4) mit ihren <strong>bidirektionalen Cross-Walks</strong>.
          Bezeichnungen FR/DE/IT/EN. Ideal für Multi-Jurisdiktions-Reporting und Time-Series-Kontinuität.
        </p>

        <div class="v4-spec-row reveal-v4" data-delay="3">
          <div class="v4-spec">
            <div class="v4-spec-label">Standards</div>
            <div class="v4-spec-value">5 vereint</div>
          </div>
          <div class="v4-spec">
            <div class="v4-spec-label">Codes</div>
            <div class="v4-spec-value">~3 800</div>
          </div>
          <div class="v4-spec">
            <div class="v4-spec-label">Cross-Walks</div>
            <div class="v4-spec-value">5-way</div>
          </div>
        </div>

        <div class="v4-cta-row reveal-v4" data-delay="4">
          <a href="#kaufen" class="v4-btn v4-btn-primary">Kaufen — 399 CHF <span class="arrow">→</span></a>
          <a href="/samples/classifications-sample.csv" download class="v4-btn v4-btn-secondary">CSV-Muster</a>
        </div>

        <div class="v4-permission-line reveal-v4" data-delay="5">
          <span><strong>Quellen:</strong> BFS · Eurostat · UN Statistics</span>
          <span style="opacity:.4">·</span>
          <span>NOGA 2025 + NACE 2.1 inklusive</span>
        </div>
      </div>

      <div class="ds-price-box reveal-v4" data-delay="2">
        <div class="ds-price-box-label">Einmalig Standard</div>
        <div class="ds-price-box-amount">399<span class="ds-price-box-currency">CHF</span></div>
        <div class="ds-price-box-renew">+160 CHF/Jahr Updates (optional) · 360 Tage Updates inklusive</div>
      </div>
    </div>
  </div>
</section>

<TrustStrip
  sources={["BFS", "Eurostat", "UN Statistics"]}
  badges={["5 vereinte Nomenklaturen", "5-way Cross-Walks", "Ed25519-signiertes Manifest"]}
/>

<section class="v4-datasets ds-page">
  <div class="container-v4">
    <div class="ds-meta-grid">
      <div class="ds-meta-card reveal-v4">
        <div class="ds-meta-label">Inhalt</div>
        <div class="ds-meta-value">5 Nomenklaturen + 5-way Cross-Walks · 4 Sprachen · CSV, JSON, Parquet, SQL · ~8-12 MB total</div>
      </div>
      <div class="ds-meta-card reveal-v4" data-delay="1">
        <div class="ds-meta-label">Updates</div>
        <div class="ds-meta-value">Jährliches Refresh + grössere Revisionen · 360 Tage inklusive · Erneuerung 160 CHF/Jahr</div>
      </div>
    </div>

    <section class="ds-section reveal-v4">
      <div class="v4-section-eyebrow">
        <strong>Umfang</strong>
        <span class="sep">/</span>
        <span>5 offizielle Standards</span>
      </div>
      <h2 class="v4-section-h2">Fünf <span class="serif">Standards</span> in einem einzigen Bundle.</h2>
      <p class="v4-section-intro">
        Alle Standards sind im selben Tabellenformat normalisiert, mit denselben Feldern (code, label_fr/de/it/en, parent, level).
        Sie können von einem zum anderen wechseln über einen einzigen SQL-Join.
      </p>

      <div class="ds-table-wrap">
        <table class="ds-table">
          <thead>
            <tr><th>Standard</th><th>Umfang</th><th>Herausgeber</th><th>Sprachen</th></tr>
          </thead>
          <tbody>
            <tr><td><strong>NOGA 2008</strong></td><td class="dim">Schweizer Wirtschaftstätigkeiten (Vermächtnis)</td><td class="dim">BFS</td><td class="mono">FR/DE/IT</td></tr>
            <tr><td><strong>NOGA 2025</strong></td><td class="dim">Schweizer Wirtschaftstätigkeiten (aktuell, Januar 2026)</td><td class="dim">BFS</td><td class="mono">FR/DE/IT/EN</td></tr>
            <tr><td><strong>NACE Rev 2</strong></td><td class="dim">Europäische Wirtschaftstätigkeiten</td><td class="dim">Eurostat</td><td class="mono">EN</td></tr>
            <tr><td><strong>NACE Rev 2.1</strong></td><td class="dim">Europäische Wirtschaftstätigkeiten (Revision)</td><td class="dim">Eurostat</td><td class="mono">EN</td></tr>
            <tr><td><strong>ISIC Rev 4</strong></td><td class="dim">Weltweite Wirtschaftstätigkeiten (UN)</td><td class="dim">UN Statistics</td><td class="mono">EN</td></tr>
          </tbody>
        </table>
      </div>
    </section>

    <section class="ds-section reveal-v4">
      <div class="v4-section-eyebrow">
        <strong>Cross-Walks</strong>
        <span class="sep">/</span>
        <span>Ein Join genügt</span>
      </div>
      <h2 class="v4-section-h2">Cross-Walks <span class="serif">5-way</span>.</h2>
      <p class="v4-section-intro">
        Eine kanonische Tabelle verknüpft jeden Code mit seinem Äquivalent in den anderen Standards.
        Beispiel: Eine Schweizer Bank klassifiziert als <code class="mono" style="background: var(--color-bg-alt); padding: 2px 6px; border-radius: 4px;">NOGA 2025 64.11</code> wird abgebildet auf:
      </p>

      <div class="ds-table-wrap">
        <table class="ds-table">
          <thead>
            <tr><th>Standard</th><th>Code</th><th>Bezeichnung</th></tr>
          </thead>
          <tbody>
            <tr><td><strong>NOGA 2025</strong></td><td class="mono">64.11</td><td class="dim">Tätigkeit der Zentralbank</td></tr>
            <tr><td>NOGA 2008</td><td class="mono">64.11</td><td class="dim">Tätigkeit der Zentralbank</td></tr>
            <tr><td>NACE Rev 2.1</td><td class="mono">64.11</td><td class="dim">Central banking</td></tr>
            <tr><td>NACE Rev 2</td><td class="mono">64.11</td><td class="dim">Central banking</td></tr>
            <tr><td>ISIC Rev 4</td><td class="mono">6411</td><td class="dim">Central banking</td></tr>
          </tbody>
        </table>
      </div>
    </section>

    <section class="ds-section reveal-v4">
      <div class="v4-section-eyebrow">
        <strong>Live-Demo</strong>
        <span class="sep">/</span>
        <span>Ohne Anmeldung</span>
      </div>
      <h2 class="v4-section-h2">Probieren Sie es <span class="serif">live</span> aus.</h2>
      <p class="v4-section-intro">Suchen Sie eine Wirtschaftstätigkeit und sehen Sie sofort ihren Code in den 5 Standards.</p>
      <ClassificationsLookup />
    </section>

    <div class="ds-sample reveal-v4">
      <h3>Kostenloses Muster — 30 NOGA-2025-Codes + 20 Cross-Walks</h3>
      <p>Kuratierter Auszug zu den Sektoren Finanz + öffentliche Verwaltung. Enthält die 5 Standards und die Brücken zwischen ihnen.</p>
      <a href="/samples/classifications-sample.csv" download class="ds-sample-dl">
        <svg viewBox="0 0 14 14" fill="none"><path d="M7 1v9M3 7l4 4 4-4M2 13h10" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
        classifications-sample.csv herunterladen
      </a>
    </div>

    <section class="ds-section reveal-v4">
      <div class="v4-section-eyebrow">
        <strong>Anwendungsfälle</strong>
        <span class="sep">/</span>
        <span>4 typische Profile</span>
      </div>
      <h2 class="v4-section-h2">An <span class="serif">wen</span> es sich richtet.</h2>
      <div class="ds-audience-grid">
        <div class="ds-audience-item">
          <strong>Datenteams Schweizer Banken &amp; Versicherer</strong>
          <span>Sektorielles Reporting, Kreditrisiko nach Tätigkeit, ESG-Datei nach regulatorischem Sektor.</span>
        </div>
        <div class="ds-audience-item">
          <strong>ERP- &amp; CRM-Integratoren</strong>
          <span>Code-Mapping in Bexio, SAP, Salesforce — Kunden und Lieferanten korrekt kategorisiert.</span>
        </div>
        <div class="ds-audience-item">
          <strong>Schweizer Filialen von EU-Konzernen</strong>
          <span>Konsolidierung mit dem NACE-Reporting des Mutterhauses ohne manuelle Nachbearbeitung.</span>
        </div>
        <div class="ds-audience-item">
          <strong>Berater &amp; Wirtschaftsforscher</strong>
          <span>Time-Series-Kontinuität durch NOGA-Revisionen. Vergleichende Branchenstudien.</span>
        </div>
      </div>
    </section>

    <section class="ds-section reveal-v4">
      <div class="v4-section-eyebrow">
        <strong>Pro Tier</strong>
        <span class="sep">/</span>
        <span>Für KI-Pipelines &amp; ernsthafte Integrationen</span>
      </div>
      <div class="cls-pro-card">
        <span class="cls-pro-tag">Neu · Pro Tier</span>
        <h2 class="v4-section-h2" style="margin-top:8px;">Classifications <span class="serif">Pro</span>.</h2>
        <p class="v4-section-intro" style="margin-bottom:24px;">
          Der gesamte Standard-Inhalt <strong>+ 3 Mehrwerte</strong>, die Ihren Daten- oder Compliance-Teams Tage von Arbeit ersparen:
        </p>

        <div class="cls-pro-grid">
          <div class="cls-pro-item">
            <div class="cls-pro-num">01 · Embeddings DE/IT/EN</div>
            <strong>Vorberechnete mehrsprachige 768d-Vektoren</strong>
            <p>Auf den 1 845 NOGA-2025-Codes × 4 Sprachen (FR + DE + IT + EN). Sofortige semantische Suche in der Sprache Ihres UI, ohne GPU. 7 380 Vektoren Parquet.</p>
          </div>
          <div class="cls-pro-item">
            <div class="cls-pro-num">02 · Cross-Walks NAICS 2022</div>
            <strong>NAICS US ↔ ISIC ↔ NACE/NOGA</strong>
            <p>Offizielle Konkordanz US Census Bureau (Public Domain) gepivotet via ISIC Rev 4. Kompatibles Reporting für US-Filialen, Salesforce NAICS und Census-Daten.</p>
          </div>
          <div class="cls-pro-item">
            <div class="cls-pro-num">03 · EN Labels NACE Rev 2.1</div>
            <strong>Offizielle englische Labels Eurostat</strong>
            <p>Eigenständige Projektion der 1 047 NACE-Rev-2.1-Codes auf Englisch (SKOS Eurostat re-use policy). Stand-alone CSV/Parquet — für Compliance-Exporte zu internationaler Muttergesellschaft, ohne JOIN.</p>
          </div>
        </div>

        <a href="https://buy.stripe.com/00w9AVbls2tq0CHgKbes000" class="v4-btn v4-btn-primary" style="background:var(--ink);">
          Classifications Pro kaufen — 999 CHF
          <span class="arrow">→</span>
        </a>
        <p class="ds-cta-sub" style="margin-top:16px;">Sichere Stripe-Zahlung · Ed25519 + RFC-3161-signiertes Manifest · 14-Tage-Refund falls nicht heruntergeladen</p>
      </div>
    </section>

    <ProductFaq productName="Classifications" />

    <div class="ds-cta" id="kaufen">
      <form method="POST" action="/api/checkout/start" class="ds-cta-form">
        <input type="hidden" name="dataset_ids" value="classifications" />
        <button type="submit" class="v4-btn v4-btn-primary v4-btn-cta">
          Classifications Standard kaufen — 399 CHF
          <span class="arrow">→</span>
        </button>
      </form>
      <p class="ds-cta-sub">Sichere Stripe-Zahlung · Sofortiger Download per E-Mail · 14-Tage-Rückerstattung ohne Bedingungen</p>
      <p class="ds-cta-alt">Oder nehmen Sie das <a href="/de/bundle">Komplett-Bundle (TARES + Classifications + FINMA) für 797 CHF</a> — Ersparnis 200 CHF (20 %).</p>
    </div>
  </div>
</section>
</BaseLayout>

<style>
  .cls-pro-card {
    padding: 36px;
    background: var(--bg-card);
    border: 2px solid var(--ink);
    border-radius: 14px;
    position: relative;
  }
  .cls-pro-tag {
    position: absolute;
    top: -12px;
    left: 24px;
    background: var(--ink);
    color: var(--bg);
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: .12em;
    text-transform: uppercase;
    font-weight: 600;
    padding: 4px 10px;
    border-radius: 4px;
  }
  .cls-pro-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 16px;
    margin-bottom: 24px;
  }
  @media (max-width: 880px) {
    .cls-pro-grid { grid-template-columns: 1fr; }
  }
  .cls-pro-item {
    padding: 18px;
    border: 1px solid var(--line);
    border-radius: 10px;
    background: var(--bg);
  }
  .cls-pro-num {
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: .08em;
    text-transform: uppercase;
    color: var(--accent);
    margin-bottom: 8px;
  }
  .cls-pro-item strong {
    display: block;
    font-size: 14px;
    color: var(--ink);
    margin-bottom: 6px;
  }
  .cls-pro-item p {
    font-size: 13px;
    color: var(--ink-soft);
    line-height: 1.5;
    margin: 0;
  }
</style>
