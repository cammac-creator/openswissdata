---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import FinmaLookup from "../../../components/FinmaLookup.astro";
import TrustStrip from "../../../components/TrustStrip.astro";
import ProductFaq from "../../../components/ProductFaq.astro";

const productJsonLd = {
  "@context": "https://schema.org",
  "@type": "Product",
  name: "FINMA Registry — Schweizer Finanz-Compliance",
  description: "Die 10 öffentlichen Bewilligungslisten der FINMA konsolidiert in einem einzigen Schema. Banken, Versicherungen, PSPs, Vermögensverwalter, SRO. Angereichert mit UID + LEI.",
  image: "https://www.openswissdata.com/og-finma.png",
  url: "https://www.openswissdata.com/de/datasets/finma",
  brand: { "@type": "Brand", name: "openswissdata" },
  category: "Reference data — financial supervision registry",
  offers: {
    "@type": "Offer",
    price: "299",
    priceCurrency: "CHF",
    availability: "https://schema.org/InStock",
    url: "https://www.openswissdata.com/de/datasets/finma#kaufen",
    priceValidUntil: "2026-12-31",
    seller: { "@type": "Organization", name: "openswissdata" },
    shippingDetails: {
      "@type": "OfferShippingDetails",
      shippingRate: { "@type": "MonetaryAmount", value: "0", currency: "CHF" },
      shippingDestination: { "@type": "DefinedRegion", addressCountry: "CH" },
      deliveryTime: {
        "@type": "ShippingDeliveryTime",
        handlingTime: { "@type": "QuantitativeValue", minValue: 0, maxValue: 0, unitCode: "DAY" },
        transitTime: { "@type": "QuantitativeValue", minValue: 0, maxValue: 0, unitCode: "DAY" },
      },
    },
    hasMerchantReturnPolicy: {
      "@type": "MerchantReturnPolicy",
      applicableCountry: "CH",
      returnPolicyCategory: "https://schema.org/MerchantReturnFiniteReturnWindow",
      merchantReturnDays: 14,
      returnMethod: "https://schema.org/ReturnByMail",
      returnFees: "https://schema.org/FreeReturn",
    },
  },
};
---
<BaseLayout
  title="FINMA-Register vereint — Schweizer Finanz-Compliance | openswissdata"
  description="Die 10 öffentlichen Bewilligungslisten der FINMA konsolidiert in einem einzigen Schema. Banken, Versicherungen, PSPs, Vermögensverwalter, SRO. Angereichert mit UID + LEI. 299 CHF einmalig."
  image="/og-finma.png"
  productJsonLd={productJsonLd}
>
<div class="bg-grid"></div>

<section class="v4-hero ds-page">
  <div class="ds-hero-banner-bg" style="background-image:url('/og-finma.png');" aria-hidden="true"></div>
  <div class="container-v4">
    <nav class="ds-breadcrumb">
      <a href="/de/">Startseite</a>
      <span class="sep">·</span>
      <a href="/de/bundle">Datasets</a>
      <span class="sep">·</span>
      <span class="current">FINMA Registry</span>
    </nav>

    <div class="v4-hero-grid">
      <div>
        <div class="v4-eyebrow reveal-v4">
          <span>FINMA · Vereintes Register</span>
          <span style="opacity:.4">·</span>
          <span>FINMA-Bewilligung erteilt 2026-05-06</span>
        </div>

        <h1 class="v4-h1 reveal-v4" data-delay="1">
          10 FINMA-Listen,<br>
          <span class="accent">ein einziges Register.</span>
        </h1>

        <p class="v4-lede reveal-v4" data-delay="2">
          Alle von der FINMA bewilligten Finanzinstitute, konsolidiert in einem vereinten Schema:
          Banken, Versicherungen, PSPs, Vermögensverwalter, Wertpapierhäuser, SRO. <strong>Angereichert mit Schweizer UID + internationalem LEI.</strong>
          Wöchentliche Updates mit 90-Tage-Changelog.
        </p>

        <div class="v4-spec-row reveal-v4" data-delay="3">
          <div class="v4-spec">
            <div class="v4-spec-label">Listen</div>
            <div class="v4-spec-value">10 vereint</div>
          </div>
          <div class="v4-spec">
            <div class="v4-spec-label">Entitäten</div>
            <div class="v4-spec-value">~2 912</div>
          </div>
          <div class="v4-spec">
            <div class="v4-spec-label">Updates</div>
            <div class="v4-spec-value">Wöchentlich</div>
          </div>
        </div>

        <div class="v4-cta-row reveal-v4" data-delay="4">
          <a href="#kaufen" class="v4-btn v4-btn-primary">Kaufen — 299 CHF <span class="arrow">→</span></a>
          <a href="/samples/finma-sample.csv" download class="v4-btn v4-btn-secondary">CSV-Muster</a>
        </div>

        <div class="v4-permission-line reveal-v4" data-delay="5">
          <span><strong>Quelle:</strong> FINMA</span>
          <span style="opacity:.4">·</span>
          <span>Offizielle öffentliche Listen</span>
          <span style="opacity:.4">·</span>
          <span><strong>Gerichtsstand:</strong> Bern</span>
        </div>
      </div>

      <div class="ds-price-box reveal-v4" data-delay="2">
        <div class="ds-price-box-label">Einmalig</div>
        <div class="ds-price-box-amount">299<span class="ds-price-box-currency">CHF</span></div>
        <div class="ds-price-box-renew">+120 CHF/Jahr Updates (optional) · 360 Tage Updates inklusive</div>
      </div>
    </div>
  </div>
</section>

<TrustStrip
  sources={["FINMA", "UID Registry", "GLEIF (LEI)"]}
  badges={["10 konsolidierte Listen", "Ed25519-signiertes Manifest", "RFC-3161 Zeitstempel"]}
/>

<section class="v4-datasets ds-page">
  <div class="container-v4">
    <div class="finma-status-banner reveal-v4">
      <div class="finma-status-icon">⚖️</div>
      <div class="finma-status-text">
        <strong>Öffentliche Daten republiziert nach Art. 5 URG · FINMA-Bewilligung erteilt</strong>
        <span>Die FINMA veröffentlicht ihre 10 Bewilligungslisten als Open Data. Wir normalisieren sie, signieren sie kryptografisch (Ed25519 + RFC-3161) und verteilen sie mit 90-Tage-Changelog. Schriftliche Republikationsbewilligung von der FINMA am <strong>6. Mai 2026</strong> erteilt (FINMA Kommunikation, Nadine Bucher) — vorbehaltlich der Wahrung der FINMA-Urheberrechte und der Integrität der Quelldokumente. <strong>24h-Takedown-Politik auf FINMA-Anfrage</strong> — siehe <a href="/de/legal/sdr-policy">SDR Policy</a>.</span>
      </div>
    </div>

    <div class="ds-meta-grid">
      <div class="ds-meta-card reveal-v4">
        <div class="ds-meta-label">Enthaltene Formate</div>
        <div class="ds-meta-value">CSV (vereint + nach Typ) · JSON · Parquet · SQL · 90-Tage-Changelog · JSON Schema · README · LICENSE · SHA-256</div>
      </div>
      <div class="ds-meta-card reveal-v4" data-delay="1">
        <div class="ds-meta-label">Updates</div>
        <div class="ds-meta-value">Wöchentlicher Diff + 90-Tage-Changelog · 360 Tage inklusive · Erneuerung 120 CHF/Jahr</div>
      </div>
    </div>

    <section class="ds-section reveal-v4">
      <div class="v4-section-eyebrow">
        <strong>Umfang</strong>
        <span class="sep">/</span>
        <span>10 FINMA-Entitätstypen</span>
      </div>
      <h2 class="v4-section-h2">10 <span class="serif">Entitätstypen</span> abgedeckt.</h2>
      <p class="v4-section-intro">
        Alle öffentlichen FINMA-Listen werden abgerufen, normalisiert und unter einem gemeinsamen Schema mit einem <code class="mono" style="background: var(--color-bg-alt); padding: 2px 6px; border-radius: 4px;">entity_type</code>-Feld zur Unterscheidung zusammengeführt.
      </p>

      <div class="ds-table-wrap">
        <table class="ds-table">
          <thead>
            <tr><th>Entitätstyp</th><th>Entsprechende FINMA-Liste</th></tr>
          </thead>
          <tbody>
            <tr><td><strong>Banken</strong></td><td class="dim">Vollbanklizenzen + kantonale + private</td></tr>
            <tr><td><strong>Versicherungen</strong></td><td class="dim">Leben + Nicht-Leben + Rückversicherung + Krankenkassen</td></tr>
            <tr><td><strong>PSP / Fintech</strong></td><td class="dim">Zahlungsinstitute, E-Geld, Fintech-Lizenz</td></tr>
            <tr><td><strong>Verwalter kollektiver Vermögen</strong></td><td class="dim">Fund Managers nach KAG/CISA</td></tr>
            <tr><td><strong>Verwalter individueller Vermögen</strong></td><td class="dim">Bewilligt nach FINIG/FinIA</td></tr>
            <tr><td><strong>Wertpapierhäuser</strong></td><td class="dim">Broker, Market Maker</td></tr>
            <tr><td><strong>Fondsvertreter</strong></td><td class="dim">Vertrieb in CH von ausländischen Fonds</td></tr>
            <tr><td><strong>SRO-Mitglieder</strong></td><td class="dim">Direkt unterstellte Finanzintermediäre (DSFI)</td></tr>
            <tr><td><strong>Aufsichtsorganisationen</strong></td><td class="dim">FIDLEG-Aufsichtsbehörden</td></tr>
            <tr><td><strong>Versicherungsvermittler</strong></td><td class="dim">Bei der FINMA registrierte Makler &amp; Agenten</td></tr>
          </tbody>
        </table>
      </div>
    </section>

    <section class="ds-section reveal-v4">
      <div class="v4-section-eyebrow">
        <strong>Schema</strong>
        <span class="sep">/</span>
        <span>Gemeinsame Felder über die 10 Listen</span>
      </div>
      <h2 class="v4-section-h2">Vereinheitlichtes <span class="serif">Schema</span> über die 10 Listen.</h2>
      <p class="v4-section-intro">
        Alle Datensätze teilen dieselben Felder. Sie können nach <code class="mono" style="background: var(--color-bg-alt); padding: 2px 6px; border-radius: 4px;">entity_type</code> filtern oder alle Institute auf einmal abfragen.
      </p>

      <div class="ds-table-wrap">
        <table class="ds-table">
          <thead>
            <tr><th>Feld</th><th>Typ</th><th>Beispiel</th></tr>
          </thead>
          <tbody>
            <tr><td class="mono">entity_type</td><td class="dim">enum (10 Werte)</td><td class="mono">bank</td></tr>
            <tr><td class="mono">name</td><td class="dim">string</td><td>UBS Switzerland AG</td></tr>
            <tr><td class="mono">uid</td><td class="dim">string (CHE-Format)</td><td class="mono">CHE-101.329.561</td></tr>
            <tr><td class="mono">lei</td><td class="dim">string (20 chars)</td><td class="mono">506700LOLO53LDMTHY00</td></tr>
            <tr><td class="mono">licence_type</td><td class="dim">string</td><td>fintech licence</td></tr>
            <tr><td class="mono">licence_date</td><td class="dim">string (ISO)</td><td class="mono">2019-08-27</td></tr>
            <tr><td class="mono">status</td><td class="dim">string</td><td class="mono">active</td></tr>
            <tr><td class="mono">canton</td><td class="dim">string (2 Buchstaben)</td><td class="mono">ZH</td></tr>
            <tr><td class="mono">address</td><td class="dim">string</td><td>Bahnhofstrasse 45, 8001 Zürich</td></tr>
            <tr><td class="mono">source_list</td><td class="dim">string</td><td class="mono">finma-banks</td></tr>
          </tbody>
        </table>
      </div>
    </section>

    <section class="ds-section reveal-v4">
      <div class="v4-section-eyebrow">
        <strong>Live-Demo</strong>
        <span class="sep">/</span>
        <span>Ohne Anmeldung</span>
      </div>
      <h2 class="v4-section-h2">Probieren Sie es <span class="serif">live</span> aus.</h2>
      <p class="v4-section-intro">Suchen Sie ein Schweizer Institut und sehen Sie sofort seinen FINMA-Typ, seine UID und seinen LEI.</p>
      <FinmaLookup />
    </section>

    <div class="ds-sample reveal-v4">
      <h3>Kostenloses Muster — 143 Entitäten aus den 9 abgedeckten Typen</h3>
      <p>Ausgewogener Auszug (bis zu 20 pro Entitätstyp, je nach verfügbaren Volumen) zur Validierung des Formats. Die 16 Spalten des vollständigen Datasets sind vorhanden (entity_type, name, uid, lei, licence_type FR/DE/IT, licence_date, status, canton, city, address, source_list, source_url, is_warning_listed).</p>
      <a href="/samples/finma-sample.csv" download class="ds-sample-dl">
        <svg viewBox="0 0 14 14" fill="none"><path d="M7 1v9M3 7l4 4 4-4M2 13h10" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
        finma-sample.csv herunterladen
      </a>
    </div>

    <section class="ds-section reveal-v4">
      <div class="v4-section-eyebrow">
        <strong>Anwendungsfälle</strong>
        <span class="sep">/</span>
        <span>4 typische Profile</span>
      </div>
      <h2 class="v4-section-h2">An <span class="serif">wen</span> es sich richtet.</h2>
      <div class="ds-audience-grid">
        <div class="ds-audience-item">
          <strong>Compliance Officers FinTech &amp; Banken</strong>
          <span>Tägliche Überprüfung von Gegenparteien, KYC Due Diligence, AML-Screening.</span>
        </div>
        <div class="ds-audience-item">
          <strong>B2B-Plattformen (Zahlung, Lending)</strong>
          <span>Automatisiertes Onboarding: prüfen, ob ein Partner FINMA-reguliert ist, in einem API-Aufruf.</span>
        </div>
        <div class="ds-audience-item">
          <strong>Finanzanwaltskanzleien</strong>
          <span>Entitätssuche, beschleunigte Due Diligence, Audit der FINMA-Bewilligungen über die Zeit.</span>
        </div>
        <div class="ds-audience-item">
          <strong>Regulatoren &amp; Forscher</strong>
          <span>Time-Series zur Entwicklung der Schweizer Finanzlandschaft, vergleichende Studien nach Kanton.</span>
        </div>
      </div>
    </section>

    <ProductFaq productName="FINMA Registry" />

    <div class="ds-cta" id="kaufen">
      <form method="POST" action="/api/checkout/start" class="ds-cta-form">
        <input type="hidden" name="dataset_ids" value="finma" />
        <button type="submit" class="v4-btn v4-btn-primary v4-btn-cta">
          FINMA Registry kaufen — 299 CHF
          <span class="arrow">→</span>
        </button>
      </form>
      <p class="ds-cta-sub">Sichere Stripe-Zahlung · Sofortiger Download per E-Mail · 14-Tage-Rückerstattung ohne Bedingungen</p>
      <p class="ds-cta-alt">Oder nehmen Sie das <a href="/de/bundle">Komplett-Bundle (TARES + Classifications + FINMA) für 797 CHF</a> — Ersparnis 200 CHF (20 %).</p>
    </div>
  </div>
</section>

<style>
  .finma-status-banner {
    display: flex;
    gap: 16px;
    align-items: flex-start;
    padding: 18px 22px;
    background: var(--bg-card);
    border: 1px solid var(--line);
    border-left: 4px solid var(--teal);
    border-radius: 10px;
    margin-bottom: 32px;
  }
  .finma-status-icon {
    font-size: 22px;
    flex-shrink: 0;
    line-height: 1;
  }
  .finma-status-text {
    flex: 1;
    font-size: 13px;
    line-height: 1.55;
    color: var(--ink-soft);
  }
  .finma-status-text strong {
    display: block;
    color: var(--ink);
    font-weight: 600;
    margin-bottom: 4px;
    font-size: 14px;
  }
  .finma-status-text span strong {
    display: inline;
    margin: 0;
    font-size: 13px;
  }
  .finma-status-text a {
    color: var(--teal);
    text-decoration: underline;
  }
</style>
</BaseLayout>
