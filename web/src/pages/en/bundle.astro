---
import BaseLayout from "../../layouts/BaseLayout.astro";
import TrustStrip from "../../components/TrustStrip.astro";
import ProductFaq from "../../components/ProductFaq.astro";

const productJsonLd = {
  "@context": "https://schema.org",
  "@type": "Product",
  name: "openswissdata bundle — TARES + Classifications + FINMA",
  description: "The 3 openswissdata datasets in a single purchase. Save 200 CHF (20%) vs buying separately. 360 days of updates included.",
  image: "https://www.openswissdata.com/og-default.png",
  url: "https://www.openswissdata.com/en/bundle",
  brand: { "@type": "Brand", name: "openswissdata" },
  category: "Reference data bundle",
  offers: {
    "@type": "Offer",
    price: "797",
    priceCurrency: "CHF",
    availability: "https://schema.org/InStock",
    url: "https://www.openswissdata.com/en/bundle#buy",
    priceValidUntil: "2026-12-31",
    seller: { "@type": "Organization", name: "openswissdata" },
  },
  isRelatedTo: [
    { "@type": "Product", name: "TARES", url: "https://www.openswissdata.com/en/datasets/tares" },
    { "@type": "Product", name: "Classifications", url: "https://www.openswissdata.com/en/datasets/classifications" },
    { "@type": "Product", name: "FINMA Registry", url: "https://www.openswissdata.com/en/datasets/finma" },
  ],
};
---
<BaseLayout
  title="Complete bundle — TARES + Classifications + FINMA | openswissdata"
  description="The 3 openswissdata datasets in a single purchase (TARES customs, Classifications NOGA/NACE/ISIC, FINMA Registry) for 797 CHF. Save 200 CHF (20%) vs buying separately."
  productJsonLd={productJsonLd}
>
<div class="bg-grid"></div>

<section class="v4-hero ds-page">
  <div class="container-v4">
    <nav class="ds-breadcrumb">
      <a href="/en/">home</a>
      <span class="sep">·</span>
      <span class="current">Complete bundle</span>
    </nav>

    <div class="v4-hero-grid">
      <div>
        <div class="v4-eyebrow reveal-v4">
          <span>3-in-1 bundle · Most popular</span>
          <span style="opacity:.4">·</span>
          <span class="check">200 CHF saved</span>
        </div>

        <h1 class="v4-h1 reveal-v4" data-delay="1">
          All of openswissdata,<br>
          <span class="accent">in a single purchase.</span>
        </h1>

        <p class="v4-lede reveal-v4" data-delay="2">
          The three datasets for teams that need a complete view of Swiss regulatory data.
          <strong>One checkout, three toolboxes.</strong> Compliance, finance, customs — all covered.
        </p>

        <div class="v4-spec-row reveal-v4" data-delay="3">
          <div class="v4-spec">
            <div class="v4-spec-label">Datasets</div>
            <div class="v4-spec-value">3 included</div>
          </div>
          <div class="v4-spec">
            <div class="v4-spec-label">Saving</div>
            <div class="v4-spec-value">200 CHF (−20%)</div>
          </div>
          <div class="v4-spec">
            <div class="v4-spec-label">Updates</div>
            <div class="v4-spec-value">360 days included</div>
          </div>
        </div>

        <div class="v4-cta-row reveal-v4" data-delay="4">
          <a href="#buy" class="v4-btn v4-btn-primary">Buy the bundle — 797 CHF <span class="arrow">→</span></a>
          <a href="#saving-detail" class="v4-btn v4-btn-secondary">See the breakdown</a>
        </div>

        <div class="v4-permission-line reveal-v4" data-delay="5">
          <span><strong>Sources:</strong> BAZG · BFS · FINMA</span>
          <span style="opacity:.4">·</span>
          <span class="ok">BAZG permission granted 2026-04-21</span>
          <span style="opacity:.4">·</span>
          <span><strong>Legal venue:</strong> Berne</span>
        </div>
      </div>

      <div class="ds-price-box reveal-v4" data-delay="2">
        <div class="ds-price-box-label">Complete bundle</div>
        <div class="bundle-price-strike">997 CHF</div>
        <div class="ds-price-box-amount accent">797<span class="ds-price-box-currency">CHF</span></div>
        <div class="ds-price-box-renew">200 CHF saved · 360 days of updates included</div>
      </div>
    </div>
  </div>
</section>

<TrustStrip
  sources={["BAZG", "BFS / OFS", "FINMA"]}
  badges={["BAZG permission · 2026-04-21", "3 unified datasets", "Ed25519-signed manifest"]}
/>

<section class="v4-datasets ds-page">
  <div class="container-v4">

    <section class="ds-section reveal-v4">
      <div class="v4-section-eyebrow">
        <strong>Bundle contents</strong>
        <span class="sep">/</span>
        <span>3 authoritative datasets</span>
      </div>
      <h2 class="v4-section-h2">Three <span class="serif">datasets</span> in the bundle.</h2>
      <div class="ds-bundle-grid">
        <a href="/en/datasets/tares" class="ds-bundle-card">
          <div class="ds-bundle-meta">Customs · BAZG ✓</div>
          <h3>TARES</h3>
          <p>~7,500 current HS8 codes (4 languages), MFN duties, up to 30+ preferential regimes per code.</p>
          <div class="ds-bundle-price">299 CHF stand-alone</div>
          <span class="ds-bundle-cta">See details →</span>
        </a>
        <a href="/en/datasets/classifications" class="ds-bundle-card">
          <div class="ds-bundle-meta">Classifications · BFS</div>
          <h3>NOGA + NACE + ISIC</h3>
          <p>5 nomenclatures + bidirectional cross-walks, 4 languages.</p>
          <div class="ds-bundle-price">399 CHF stand-alone</div>
          <span class="ds-bundle-cta">See details →</span>
        </a>
        <a href="/en/datasets/finma" class="ds-bundle-card">
          <div class="ds-bundle-meta">Compliance · FINMA</div>
          <h3>FINMA Registry</h3>
          <p>10 unified authorisation lists, enriched with UID + LEI.</p>
          <div class="ds-bundle-price">299 CHF stand-alone</div>
          <span class="ds-bundle-cta">See details →</span>
        </a>
      </div>

      <div style="margin-top: 20px; padding: 16px 20px; background: var(--bg-card); border: 1px solid var(--line); border-radius: 10px; font-size: 13px; color: var(--ink-soft); line-height: 1.55;">
        <strong style="color: var(--ink);">+ Included with the bundle:</strong> Standard access to the MCP server (1,000 req/month for 12 months on the 9 core tools — <code style="font-size: 12px;">tariff_lookup</code>, <code style="font-size: 12px;">kyc_check</code>, <code style="font-size: 12px;">cross_walk</code>, <code style="font-size: 12px;">finma_search</code>, <code style="font-size: 12px;">tariff_changelog</code>, <code style="font-size: 12px;">entity_history</code>, <code style="font-size: 12px;">classify_text</code>, <code style="font-size: 12px;">tariff_semantic_search</code>, <code style="font-size: 12px;">statent_lookup</code>). See <a href="/en/mcp" style="color: var(--accent);">the MCP page</a> for details.
      </div>
    </section>

    <section class="ds-section reveal-v4" id="saving-detail">
      <div class="v4-section-eyebrow">
        <strong>Savings</strong>
        <span class="sep">/</span>
        <span>Price detail vs bundle</span>
      </div>
      <h2 class="v4-section-h2">The <span class="serif">breakdown</span> of your savings.</h2>
      <div class="ds-saving-table">
        <div class="ds-saving-row">
          <span>TARES</span>
          <span class="mono">299 CHF</span>
        </div>
        <div class="ds-saving-row">
          <span>Classifications Bundle</span>
          <span class="mono">399 CHF</span>
        </div>
        <div class="ds-saving-row">
          <span>FINMA Registry</span>
          <span class="mono">299 CHF</span>
        </div>
        <div class="ds-saving-row separator">
          <span>Total bought separately</span>
          <span class="mono">997 CHF</span>
        </div>
        <div class="ds-saving-row highlight">
          <span>Complete bundle</span>
          <span class="mono">797 CHF</span>
        </div>
        <div class="ds-saving-row save">
          <span>You save</span>
          <span class="mono">−200 CHF (20%)</span>
        </div>
      </div>
    </section>

    <section class="ds-section reveal-v4">
      <div class="v4-section-eyebrow">
        <strong>Updates</strong>
        <span class="sep">/</span>
        <span>No commitment</span>
      </div>
      <h2 class="v4-section-h2">The <span class="serif">updates</span>.</h2>
      <p class="v4-section-intro">
        360 days of updates for all 3 datasets included in the price.
        After that: per-dataset renewal (120 CHF/year for TARES and FINMA, 160 CHF/year for Classifications) or you keep the versions you have.
        <strong>No commitment, no auto-renewal.</strong>
      </p>
    </section>

    <section class="ds-section reveal-v4">
      <div class="v4-section-eyebrow">
        <strong>Use cases</strong>
        <span class="sep">/</span>
        <span>4 typical profiles</span>
      </div>
      <h2 class="v4-section-h2">Who is the <span class="serif">bundle</span> for?</h2>
      <div class="ds-audience-grid">
        <div class="ds-audience-item">
          <strong>Full-stack data teams</strong>
          <span>Banks, insurers, FinTech, B2B platforms. Everything under one roof, same formats, same versioning.</span>
        </div>
        <div class="ds-audience-item">
          <strong>Swiss SaaS publishers</strong>
          <span>ERP, CRM, accounting: integrate the 3 datasets once and serve all industries.</span>
        </div>
        <div class="ds-audience-item">
          <strong>Consulting and law firms</strong>
          <span>Complete toolbox for due diligence, KYC, customs audits, sectoral studies.</span>
        </div>
        <div class="ds-audience-item">
          <strong>Anyone weighing the DIY option</strong>
          <span>If you have already started scraping one of these sources, you know the hidden cost. The bundle pays back its ROI in less than a week.</span>
        </div>
      </div>
    </section>

    <ProductFaq productName="3-in-1 bundle" refundClause="Full refund within 14 days if none of the 3 ZIPs has been downloaded." />

    <div class="ds-cta" id="buy">
      <form method="POST" action="/api/checkout/start" class="ds-cta-form">
        <input type="hidden" name="dataset_ids" value="bundle" />
        <button type="submit" class="v4-btn v4-btn-primary v4-btn-cta">
          Buy the complete bundle — 797 CHF
          <span class="arrow">→</span>
        </button>
      </form>
      <p class="ds-cta-sub">Secure Stripe payment · 3 immediate downloads by email · 14-day refund if none downloaded · Priority email support included</p>
    </div>
  </div>
</section>

<style>
  .bundle-price-strike {
    font-family: var(--font-mono);
    font-size: 13px;
    color: var(--ink-mute);
    text-decoration: line-through;
    margin-bottom: 4px;
  }
  .v4-hero.ds-page .ds-price-box .ds-price-box-amount.accent { color: var(--accent); }

  .ds-bundle-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 16px;
  }
  @media (max-width: 880px) { .ds-bundle-grid { grid-template-columns: 1fr; } }

  .ds-bundle-card {
    background: var(--bg-card);
    border: 1px solid var(--line);
    border-radius: 14px;
    padding: 24px;
    text-decoration: none;
    color: inherit;
    transition: transform .25s ease, border-color .25s ease, box-shadow .25s ease;
    display: block;
  }
  .ds-bundle-card:hover {
    transform: translateY(-3px);
    border-color: var(--color-accent);
    box-shadow: var(--shadow-md);
  }
  .ds-bundle-meta {
    font-family: var(--font-mono);
    font-size: 10px;
    text-transform: uppercase;
    letter-spacing: .06em;
    color: var(--color-ink-mute);
    margin-bottom: 12px;
  }
  .ds-bundle-card h3 {
    font-size: 18px;
    margin: 0 0 8px;
  }
  .ds-bundle-card p {
    font-size: 13px;
    color: var(--color-ink-soft);
    line-height: 1.55;
    margin: 0 0 16px;
  }
  .ds-bundle-price {
    font-family: var(--font-mono);
    font-size: 11px;
    color: var(--color-ink-mute);
    padding-top: 12px;
    border-top: 1px solid var(--color-line-soft);
  }
  .ds-bundle-cta {
    display: block;
    margin-top: 12px;
    font-size: 13px;
    color: var(--color-accent);
    font-weight: 500;
  }

  .ds-saving-table {
    background: var(--bg-card);
    border: 1px solid var(--line);
    border-radius: 14px;
    padding: 8px 24px;
  }
  .ds-saving-row {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 14px 0;
    font-size: 14px;
    color: var(--color-ink-soft);
  }
  .ds-saving-row .mono {
    font-family: var(--font-mono);
    color: var(--color-ink-soft);
  }
  .ds-saving-row.separator {
    border-top: 1px solid var(--color-line);
    color: var(--color-ink);
    font-weight: 500;
  }
  .ds-saving-row.separator .mono { color: var(--color-ink); }
  .ds-saving-row.highlight {
    color: var(--color-ink);
    font-weight: 600;
    font-size: 16px;
  }
  .ds-saving-row.highlight .mono { color: var(--color-ink); font-weight: 600; }
  .ds-saving-row.save {
    color: var(--color-accent);
    font-weight: 600;
    background: var(--color-accent-soft);
    margin: 4px -24px -8px;
    padding: 14px 24px;
    border-radius: 0 0 14px 14px;
  }
  .ds-saving-row.save .mono { color: var(--color-accent); font-weight: 700; }
  @media (max-width: 540px) {
    .ds-saving-table { padding: 8px 16px; }
    .ds-saving-row.save { margin: 4px -16px -8px; padding: 14px 16px; }
    .ds-saving-row { font-size: 13px; }
  }
</style>
</BaseLayout>
