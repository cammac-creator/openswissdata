---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import HSLookup from "../../../components/HSLookup.astro";
import TrustStrip from "../../../components/TrustStrip.astro";
import ProductFaq from "../../../components/ProductFaq.astro";

const productJsonLd = {
  "@context": "https://schema.org",
  "@type": "Product",
  name: "TARES — Swiss customs tariff, normalised",
  description: "~7,500 current HS8 codes, descriptions in DE/FR/IT/EN, MFN duties, 30+ preferential regimes (EU/EFTA/UK/China/Japan…), customs relief codes. JSON / Parquet / SQL.",
  image: "https://www.openswissdata.com/og-default.png",
  url: "https://www.openswissdata.com/en/datasets/tares",
  brand: { "@type": "Brand", name: "openswissdata" },
  category: "Reference data — customs tariff",
  offers: {
    "@type": "Offer",
    price: "299",
    priceCurrency: "CHF",
    availability: "https://schema.org/InStock",
    url: "https://www.openswissdata.com/en/datasets/tares#buy",
    priceValidUntil: "2026-12-31",
    seller: { "@type": "Organization", name: "openswissdata" },
  },
};
---
<BaseLayout
  title="TARES — Swiss customs tariff, normalised | openswissdata"
  description="Complete Swiss customs tariff: ~7,500 current HS8 codes, descriptions in DE/FR/IT/EN, MFN duties, 30+ preferential regimes (EU/EFTA/UK/China/Japan…), customs relief codes. JSON / Parquet / SQL. 299 CHF one-shot."
  productJsonLd={productJsonLd}
>
<div class="bg-grid"></div>

<section class="v4-hero ds-page">
  <div class="container-v4">
    <nav class="ds-breadcrumb">
      <a href="/en/">home</a>
      <span class="sep">·</span>
      <a href="/en/bundle">datasets</a>
      <span class="sep">·</span>
      <span class="current">TARES</span>
    </nav>

    <div class="v4-hero-grid">
      <div>
        <div class="v4-eyebrow reveal-v4">
          <span>TARES · Swiss customs tariff</span>
          <span style="opacity:.4">·</span>
          <span class="check">BAZG permission · 2026-04-21</span>
        </div>

        <h1 class="v4-h1 reveal-v4" data-delay="1">
          The Swiss customs tariff,<br>
          <span class="accent">clean.</span>
        </h1>

        <p class="v4-lede reveal-v4" data-delay="2">
          ~7,500 current HS8 codes, descriptions in 4 languages (DE/FR/IT/EN),
          MFN duties with value + unit, up to <strong>30+ preferential regimes per code</strong>
          (EU, EFTA, UK, China, Japan, Korea…). Weekly updates from the official BAZG XLSX files.
        </p>

        <div class="v4-spec-row reveal-v4" data-delay="3">
          <div class="v4-spec">
            <div class="v4-spec-label">HS8 codes</div>
            <div class="v4-spec-value">~7,500</div>
          </div>
          <div class="v4-spec">
            <div class="v4-spec-label">Languages</div>
            <div class="v4-spec-value">DE · FR · IT · EN</div>
          </div>
          <div class="v4-spec">
            <div class="v4-spec-label">Updates</div>
            <div class="v4-spec-value">Weekly</div>
          </div>
        </div>

        <div class="v4-cta-row reveal-v4" data-delay="4">
          <a href="#buy" class="v4-btn v4-btn-primary">Buy — 299 CHF <span class="arrow">→</span></a>
          <a href="/samples/tares-sample.csv" download class="v4-btn v4-btn-secondary">CSV sample</a>
        </div>

        <div class="v4-permission-line reveal-v4" data-delay="5">
          <span><strong>Source:</strong> BAZG · xtares.admin.ch</span>
          <span style="opacity:.4">·</span>
          <span class="ok">Permission granted 2026-04-21</span>
          <span style="opacity:.4">·</span>
          <span><strong>Legal venue:</strong> Berne</span>
        </div>
      </div>

      <div class="ds-price-box reveal-v4" data-delay="2">
        <div class="ds-price-box-label">One-shot</div>
        <div class="ds-price-box-amount">299<span class="ds-price-box-currency">CHF</span></div>
        <div class="ds-price-box-renew">+120 CHF/year for updates (optional) · 360 days of updates included</div>
      </div>
    </div>
  </div>
</section>

<TrustStrip
  sources={["BAZG", "xtares.admin.ch"]}
  badges={["BAZG permission · 2026-04-21", "Ed25519-signed manifest", "RFC-3161 timestamp"]}
/>

<section class="v4-datasets ds-page">
  <div class="container-v4">
    <div class="ds-disclaimer reveal-v4">
      <p><strong>⚠ Non-officiel · Nicht-offiziell · Non ufficiale · Non-official</strong></p>
      <p>
        Only the official publications of the Federal Chancellery and BAZG are authoritative.
        Authoritative source: <a href="https://xtares.admin.ch/" target="_blank" rel="noopener">xtares.admin.ch</a>.
        Legal venue for TARES disputes: Berne, Switzerland.
      </p>
    </div>

    <div class="ds-meta-grid">
      <div class="ds-meta-card reveal-v4">
        <div class="ds-meta-label">Included formats</div>
        <div class="ds-meta-value">CSV · JSON · Parquet · SQL · JSON Schema · README · SHA-256 checksums · LICENSE</div>
      </div>
      <div class="ds-meta-card reveal-v4" data-delay="1">
        <div class="ds-meta-label">Updates</div>
        <div class="ds-meta-value">Weekly delta following BAZG publications · 360 days included · 120 CHF/year renewal</div>
      </div>
    </div>

    <section class="ds-section reveal-v4">
      <div class="v4-section-eyebrow">
        <strong>TARES schema</strong>
        <span class="sep">/</span>
        <span>17 normalised columns</span>
      </div>
      <h2 class="v4-section-h2">The <span class="serif">schema</span> at a glance.</h2>
      <p class="v4-section-intro">
        Each row represents an 8-digit HS code with its multilingual descriptions, applicable duties and preferential agreements.
      </p>

      <div class="ds-table-wrap">
        <table class="ds-table">
          <thead>
            <tr><th>Field</th><th>Type</th><th>Example</th></tr>
          </thead>
          <tbody>
            <tr><td class="mono">hs8</td><td class="dim">string (8 digits)</td><td class="mono">84820010</td></tr>
            <tr><td class="mono">hs6</td><td class="dim">string (6 digits)</td><td class="mono">848200</td></tr>
            <tr><td class="mono">designation_fr</td><td class="dim">string</td><td>Roulements à billes, à contact radial</td></tr>
            <tr><td class="mono">designation_de</td><td class="dim">string</td><td>Kugellager, mit radialer Berührung</td></tr>
            <tr><td class="mono">designation_it</td><td class="dim">string</td><td>Cuscinetti a sfere, contatto radiale</td></tr>
            <tr><td class="mono">unit_stat</td><td class="dim">string</td><td>per 100 kg gross</td></tr>
            <tr><td class="mono">duty_mfn_value</td><td class="dim">number</td><td class="mono">0.00</td></tr>
            <tr><td class="mono">duty_mfn_unit</td><td class="dim">string</td><td>per 100 kg gross</td></tr>
            <tr><td class="mono">duty_mfn_currency</td><td class="dim">string</td><td class="mono">CHF</td></tr>
            <tr><td class="mono">preferential_regimes</td><td class="dim">object</td><td class="mono" is:raw>{"eu":"free","efta":"free","japon":"free"}</td></tr>
            <tr><td class="mono">customs_relief_codes</td><td class="dim">string[]</td><td class="mono">["01"]</td></tr>
          </tbody>
        </table>
      </div>
    </section>

    <section class="ds-section reveal-v4">
      <div class="v4-section-eyebrow">
        <strong>Live demo</strong>
        <span class="sep">/</span>
        <span>No sign-up</span>
      </div>
      <h2 class="v4-section-h2">Try it <span class="serif">for real</span>.</h2>
      <p class="v4-section-intro">Search for a product or HS code and see the result — exactly as your ERP would via our API.</p>
      <HSLookup />
    </section>

    <div class="ds-sample reveal-v4">
      <h3>Free sample — 100 rows (CSV)</h3>
      <p>Curated preview covering varied chapters (food, mechanical, electronics, textile). To validate that the format suits you before purchase.</p>
      <a href="/samples/tares-sample.csv" download class="ds-sample-dl">
        <svg viewBox="0 0 14 14" fill="none"><path d="M7 1v9M3 7l4 4 4-4M2 13h10" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
        Download tares-sample.csv
      </a>
    </div>

    <section class="ds-section reveal-v4">
      <div class="v4-section-eyebrow">
        <strong>Use cases</strong>
        <span class="sep">/</span>
        <span>4 typical profiles</span>
      </div>
      <h2 class="v4-section-h2">Who <span class="serif">it's for</span>.</h2>
      <div class="ds-audience-grid">
        <div class="ds-audience-item">
          <strong>Customs brokers &amp; declarants</strong>
          <span>Classify CH-EU imports/exports consistently and auditably.</span>
        </div>
        <div class="ds-audience-item">
          <strong>Customs ERP modules</strong>
          <span>SAP GTS, Descartes, Thomson Reuters ONESOURCE integrations for Swiss subsidiaries.</span>
        </div>
        <div class="ds-audience-item">
          <strong>Cross-border e-commerce</strong>
          <span>HS8 resolution at checkout for DDP/DAP CH-EU — no customs blockage.</span>
        </div>
        <div class="ds-audience-item">
          <strong>Data &amp; finance teams</strong>
          <span>Reference tables for analytics, tax reporting, import cost control.</span>
        </div>
      </div>
    </section>

    <ProductFaq productName="TARES" formatNote="CSV (100-row sample), JSON, Parquet and SQL included in every purchase." />

    <div class="ds-cta" id="buy">
      <form method="POST" action="/api/checkout/start" class="ds-cta-form">
        <input type="hidden" name="dataset_ids" value="tares" />
        <button type="submit" class="v4-btn v4-btn-primary v4-btn-cta">
          Buy TARES — 299 CHF
          <span class="arrow">→</span>
        </button>
      </form>
      <p class="ds-cta-sub">Secure Stripe payment · Immediate download by email · 14-day refund, no questions asked</p>
      <p class="ds-cta-alt">Or take the <a href="/en/bundle">complete bundle (TARES + Classifications + FINMA) for 797 CHF</a> — save 200 CHF (20%).</p>
    </div>
  </div>
</section>
</BaseLayout>
