        </tr>
        <tr>
          <td class="px-3 py-2 align-top">NOGA / NACE / ISIC classifications</td>
          <td class="px-3 py-2 align-top">OFS — Federal Statistical Office (NOGA) · Eurostat (NACE) · United Nations (ISIC)</td>
          <td class="px-3 py-2 align-top"><a href="https://www.bfs.admin.ch/" target="_blank" rel="noopener" class="text-indigo-600 hover:underline">bfs.admin.ch</a></td>
          <td class="px-3 py-2 align-top">Annual</td>
          <td class="px-3 py-2 align-top">Request sent 2026-04-17 · Awaiting OFS reply</td>
        </tr>
        <tr>
          <td class="px-3 py-2 align-top">FINMA Registry</td>
          <td class="px-3 py-2 align-top">FINMA — Swiss Financial Market Supervisory Authority</td>
          <td class="px-3 py-2 align-top"><a href="https://www.finma.ch/" target="_blank" rel="noopener" class="text-indigo-600 hover:underline">finma.ch</a></td>
