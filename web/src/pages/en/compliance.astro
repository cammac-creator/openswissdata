          <th class="text-left px-3 py-2 border-b border-slate-300">Official source</th>
          <th class="text-left px-3 py-2 border-b border-slate-300">URL</th>
          <th class="text-left px-3 py-2 border-b border-slate-300">Refresh</th>
          <th class="text-left px-3 py-2 border-b border-slate-300">Status</th>
        </tr>
      </thead>
      <tbody>
        <tr>
          <td class="px-3 py-2 align-top">TARES (customs)</td>
          <td class="px-3 py-2 align-top">BAZG — Swiss Federal Office for Customs and Border Security</td>
          <td class="px-3 py-2 align-top"><a href="https://www.bazg.admin.ch/" target="_blank" rel="noopener" class="text-indigo-600 hover:underline">bazg.admin.ch</a></td>
