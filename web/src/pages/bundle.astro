---
import BaseLayout from "../layouts/BaseLayout.astro";
const STRIPE_CHECKOUT_URL = "/api/checkout/session?dataset=bundle";
---
<BaseLayout
  title="Full Bundle — TARES + Classifications + FINMA | openswissdata"
  description="All 3 datasets (TARES customs, Classifications NOGA/NACE/ISIC, FINMA Registry) for CHF 799. Save CHF 200 vs buying separately."
>
  <section class="max-w-4xl mx-auto px-6 py-16">
    <nav class="text-sm text-slate-500 mb-4">
      <a href="/" class="hover:underline">Home</a> · <span>Full bundle</span>
    </nav>

    <div class="flex items-baseline justify-between flex-wrap gap-4 mb-2">
      <h1 class="text-4xl font-bold">Full Bundle — 3 datasets</h1>
      <div class="flex items-baseline gap-3">
        <div class="text-lg text-slate-400 line-through">CHF 997</div>
        <div class="text-3xl font-bold text-indigo-600">CHF 799</div>
      </div>
    </div>

    <p class="text-lg text-slate-600 mb-8">
      All three openswissdata datasets in one purchase. Save CHF 200 vs buying each separately. Compliance teams, data engineers, and ERP integrators — one checkout, three toolboxes.
    </p>

    <div class="grid md:grid-cols-3 gap-4 mb-10">
      <a href="/datasets/tares" class="border border-slate-200 rounded-lg p-5 hover:border-indigo-300 hover:bg-slate-50 transition-colors">
        <div class="text-sm text-slate-500 mb-1">Customs</div>
        <div class="font-semibold text-slate-900 mb-2">TARES</div>
        <div class="text-sm text-slate-600 mb-3">~6 000 HS8 codes with duties, preferential regimes, FR/DE/IT/EN labels.</div>
        <div class="text-sm text-indigo-600">View details →</div>
      </a>
      <a href="/datasets/classifications" class="border border-slate-200 rounded-lg p-5 hover:border-indigo-300 hover:bg-slate-50 transition-colors">
        <div class="text-sm text-slate-500 mb-1">Classifications</div>
        <div class="font-semibold text-slate-900 mb-2">NOGA + NACE + ISIC</div>
        <div class="text-sm text-slate-600 mb-3">5 nomenclatures + 5-way cross-walks, 4 languages.</div>
        <div class="text-sm text-indigo-600">View details →</div>
      </a>
      <a href="/datasets/finma" class="border border-slate-200 rounded-lg p-5 hover:border-indigo-300 hover:bg-slate-50 transition-colors">
        <div class="text-sm text-slate-500 mb-1">Compliance</div>
        <div class="font-semibold text-slate-900 mb-2">FINMA Registry</div>
        <div class="text-sm text-slate-600 mb-3">All 10 authorised-institution lists unified, with UID + LEI enrichment.</div>
        <div class="text-sm text-indigo-600">View details →</div>
      </a>
    </div>

    <div class="bg-indigo-50 border border-indigo-100 rounded-lg p-6 mb-10">
      <h3 class="font-semibold text-slate-900 mb-2">What you save</h3>
      <div class="text-sm text-slate-700 space-y-1">
        <div class="flex justify-between"><span>TARES</span><span class="font-mono">CHF 299</span></div>
        <div class="flex justify-between"><span>Classifications Bundle</span><span class="font-mono">CHF 399</span></div>
        <div class="flex justify-between"><span>FINMA Registry</span><span class="font-mono">CHF 299</span></div>
        <div class="flex justify-between border-t border-indigo-200 pt-2 mt-2"><span>Total separately</span><span class="font-mono">CHF 997</span></div>
        <div class="flex justify-between text-indigo-700 font-semibold"><span>Bundle price</span><span class="font-mono">CHF 799</span></div>
        <div class="flex justify-between text-emerald-700 font-bold"><span>You save</span><span class="font-mono">−CHF 200 (20%)</span></div>
      </div>
    </div>

    <h2 class="text-2xl font-semibold mb-3">Updates policy</h2>
    <p class="text-slate-700 mb-8">
      360 days of free updates for all 3 datasets included. After 1 year, renew per dataset (CHF 120/year for TARES and FINMA, CHF 160/year for Classifications) or skip and keep using the version you own.
    </p>

    <div class="border-t border-slate-200 pt-10 mt-10 text-center">
      <a href={STRIPE_CHECKOUT_URL} class="inline-block px-10 py-4 rounded-lg bg-indigo-600 hover:bg-indigo-700 text-white text-lg font-semibold transition-colors">
        Buy the Full Bundle — CHF 799
      </a>
      <p class="text-xs text-slate-500 mt-3">Secure checkout via Stripe · 3 instant downloads by email · 14-day refund if none downloaded</p>
    </div>
  </section>
</BaseLayout>
