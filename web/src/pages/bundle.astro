---
import BaseLayout from "../layouts/BaseLayout.astro";
import TrustStrip from "../components/TrustStrip.astro";

const productJsonLd = {
  "@context": "https://schema.org",
  "@type": "Product",
  name: "Bundle openswissdata — TARES + Classifications + FINMA",
  description: "Les 3 datasets openswissdata en un seul achat. Économie 200 CHF (20 %) vs achat séparé. 360 jours de mises à jour incluses.",
  image: "https://www.openswissdata.com/og-default.png",
  url: "https://www.openswissdata.com/bundle",
  brand: { "@type": "Brand", name: "openswissdata" },
  category: "Reference data bundle",
  offers: {
    "@type": "Offer",
    price: "797",
    priceCurrency: "CHF",
    availability: "https://schema.org/InStock",
    url: "https://www.openswissdata.com/bundle#acheter",
    priceValidUntil: "2026-12-31",
    seller: { "@type": "Organization", name: "openswissdata" },
  },
  isRelatedTo: [
    { "@type": "Product", name: "TARES", url: "https://www.openswissdata.com/datasets/tares" },
    { "@type": "Product", name: "Classifications", url: "https://www.openswissdata.com/datasets/classifications" },
    { "@type": "Product", name: "FINMA Registry", url: "https://www.openswissdata.com/datasets/finma" },
  ],
};
---
<BaseLayout
  title="Bundle complet — TARES + Classifications + FINMA | openswissdata"
  description="Les 3 datasets openswissdata en un seul achat (TARES douanes, Classifications NOGA/NACE/ISIC, Registre FINMA) pour 797 CHF. Économisez 200 CHF (20 %) vs achat séparé."
  productJsonLd={productJsonLd}
>
<div class="bg-grid"></div>

<section class="v4-hero ds-page">
  <div class="container-v4">
    <nav class="ds-breadcrumb">
      <a href="/">accueil</a>
      <span class="sep">·</span>
      <span class="current">Bundle complet</span>
    </nav>

    <div class="v4-hero-grid">
      <div>
        <div class="v4-eyebrow reveal-v4">
          <span>Bundle 3-en-1 · Le plus populaire</span>
          <span style="opacity:.4">·</span>
          <span class="check">200 CHF économisés</span>
        </div>

        <h1 class="v4-h1 reveal-v4" data-delay="1">
          Tout openswissdata,<br>
          <span class="accent">en un seul achat.</span>
        </h1>

        <p class="v4-lede reveal-v4" data-delay="2">
          Les trois datasets pour les équipes qui ont besoin d'une vision complète des données réglementaires suisses.
          <strong>Un seul checkout, trois boîtes à outils.</strong> Compliance, finance, douanes — couvert.
        </p>

        <div class="v4-spec-row reveal-v4" data-delay="3">
          <div class="v4-spec">
            <div class="v4-spec-label">Datasets</div>
            <div class="v4-spec-value">3 inclus</div>
          </div>
          <div class="v4-spec">
            <div class="v4-spec-label">Économie</div>
            <div class="v4-spec-value">200 CHF (−20 %)</div>
          </div>
          <div class="v4-spec">
            <div class="v4-spec-label">Mises à jour</div>
            <div class="v4-spec-value">360 jours inclus</div>
          </div>
        </div>

        <div class="v4-cta-row reveal-v4" data-delay="4">
          <a href="#acheter" class="v4-btn v4-btn-primary">Acheter le bundle — 797 CHF <span class="arrow">→</span></a>
          <a href="#detail-economie" class="v4-btn v4-btn-secondary">Voir le détail</a>
        </div>

        <div class="v4-permission-line reveal-v4" data-delay="5">
          <span><strong>Sources :</strong> BAZG · BFS · FINMA</span>
          <span style="opacity:.4">·</span>
          <span class="ok">Permission BAZG accordée 2026-04-21</span>
          <span style="opacity:.4">·</span>
          <span><strong>For :</strong> Berne</span>
        </div>
      </div>

      <div class="ds-price-box reveal-v4" data-delay="2">
        <div class="ds-price-box-label">Bundle complet</div>
        <div class="bundle-price-strike">997 CHF</div>
        <div class="ds-price-box-amount accent">797<span class="ds-price-box-currency">CHF</span></div>
        <div class="ds-price-box-renew">200 CHF économisés · 360 jours d'updates inclus</div>
      </div>
    </div>
  </div>
</section>

<TrustStrip
  sources={["BAZG", "BFS / OFS", "FINMA"]}
  badges={["Permission BAZG · 2026-04-21", "3 datasets unifiés", "Manifest signé Ed25519"]}
/>

<section class="v4-datasets ds-page">
  <div class="container-v4">

    <section class="ds-section reveal-v4">
      <div class="v4-section-eyebrow">
        <strong>Contenu du bundle</strong>
        <span class="sep">/</span>
        <span>3 datasets autoritaires</span>
      </div>
      <h2 class="v4-section-h2">Trois <span class="serif">datasets</span> dans le bundle.</h2>
      <div class="ds-bundle-grid">
        <a href="/datasets/tares" class="ds-bundle-card">
          <div class="ds-bundle-meta">Douanes · BAZG ✓</div>
          <h3>TARES</h3>
          <p>~7 500 codes HS8 actuels (4 langues), droits MFN, jusqu'à 30+ régimes préférentiels par code.</p>
          <div class="ds-bundle-price">299 CHF en standalone</div>
          <span class="ds-bundle-cta">Voir détails →</span>
        </a>
        <a href="/datasets/classifications" class="ds-bundle-card">
          <div class="ds-bundle-meta">Classifications · BFS</div>
          <h3>NOGA + NACE + ISIC</h3>
          <p>5 nomenclatures + cross-walks bidirectionnels, 4 langues.</p>
          <div class="ds-bundle-price">399 CHF en standalone</div>
          <span class="ds-bundle-cta">Voir détails →</span>
        </a>
        <a href="/datasets/finma" class="ds-bundle-card">
          <div class="ds-bundle-meta">Compliance · FINMA</div>
          <h3>FINMA Registry</h3>
          <p>10 listes d'autorisation unifiées, enrichies UID + LEI.</p>
          <div class="ds-bundle-price">299 CHF en standalone</div>
          <span class="ds-bundle-cta">Voir détails →</span>
        </a>
      </div>
    </section>

    <section class="ds-section reveal-v4" id="detail-economie">
      <div class="v4-section-eyebrow">
        <strong>Économie</strong>
        <span class="sep">/</span>
        <span>Détail prix vs bundle</span>
      </div>
      <h2 class="v4-section-h2">Le <span class="serif">détail</span> de l'économie.</h2>
      <div class="ds-saving-table">
        <div class="ds-saving-row">
          <span>TARES</span>
          <span class="mono">299 CHF</span>
        </div>
        <div class="ds-saving-row">
          <span>Classifications Bundle</span>
          <span class="mono">399 CHF</span>
        </div>
        <div class="ds-saving-row">
          <span>FINMA Registry</span>
          <span class="mono">299 CHF</span>
        </div>
        <div class="ds-saving-row separator">
          <span>Total séparé</span>
          <span class="mono">997 CHF</span>
        </div>
        <div class="ds-saving-row highlight">
          <span>Bundle complet</span>
          <span class="mono">797 CHF</span>
        </div>
        <div class="ds-saving-row save">
          <span>Vous économisez</span>
          <span class="mono">−200 CHF (20 %)</span>
        </div>
      </div>
    </section>

    <section class="ds-section reveal-v4">
      <div class="v4-section-eyebrow">
        <strong>Mises à jour</strong>
        <span class="sep">/</span>
        <span>Pas d'engagement</span>
      </div>
      <h2 class="v4-section-h2">Les <span class="serif">mises à jour</span>.</h2>
      <p class="v4-section-intro">
        360 jours de mises à jour pour les 3 datasets inclus dans le prix.
        Au-delà : renouvellement par dataset (120 CHF/an pour TARES et FINMA, 160 CHF/an pour Classifications) ou vous gardez les versions que vous avez.
        <strong>Pas d'engagement, pas d'auto-renouvellement.</strong>
      </p>
    </section>

    <section class="ds-section reveal-v4">
      <div class="v4-section-eyebrow">
        <strong>Cas d'usage</strong>
        <span class="sep">/</span>
        <span>4 profils types</span>
      </div>
      <h2 class="v4-section-h2">Pour <span class="serif">qui</span> est le bundle ?</h2>
      <div class="ds-audience-grid">
        <div class="ds-audience-item">
          <strong>Équipes data complètes</strong>
          <span>Banques, assurances, FinTech, plateformes B2B. Tout est sous un toit, mêmes formats, même versionnage.</span>
        </div>
        <div class="ds-audience-item">
          <strong>Éditeurs SaaS suisses</strong>
          <span>ERP, CRM, comptables : intégrer les 3 datasets une seule fois pour servir toutes les industries.</span>
        </div>
        <div class="ds-audience-item">
          <strong>Cabinets de conseil &amp; d'avocats</strong>
          <span>Boîte à outils complète pour due diligence, KYC, audit douanier, études sectorielles.</span>
        </div>
        <div class="ds-audience-item">
          <strong>Tous ceux qui pèsent l'option DIY</strong>
          <span>Si vous avez déjà commencé à scraper une de ces sources, vous savez le coût caché. Le bundle paie son ROI en moins d'une semaine.</span>
        </div>
      </div>
    </section>

    <div class="ds-cta" id="acheter">
      <form method="POST" action="/api/checkout/start" class="ds-cta-form">
        <input type="hidden" name="dataset_ids" value="bundle" />
        <button type="submit" class="v4-btn v4-btn-primary v4-btn-cta">
          Acheter le bundle complet — 797 CHF
          <span class="arrow">→</span>
        </button>
      </form>
      <p class="ds-cta-sub">Paiement sécurisé Stripe · 3 téléchargements immédiats par email · Remboursement 14 jours si aucun téléchargé · Support email prioritaire inclus</p>
    </div>
  </div>
</section>

<style>
  .bundle-price-strike {
    font-family: var(--font-mono);
    font-size: 13px;
    color: var(--ink-mute);
    text-decoration: line-through;
    margin-bottom: 4px;
  }
  .v4-hero.ds-page .ds-price-box .ds-price-box-amount.accent { color: var(--accent); }

  .ds-bundle-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 16px;
  }
  @media (max-width: 880px) { .ds-bundle-grid { grid-template-columns: 1fr; } }

  .ds-bundle-card {
    background: var(--bg-card);
    border: 1px solid var(--line);
    border-radius: 14px;
    padding: 24px;
    text-decoration: none;
    color: inherit;
    transition: transform .25s ease, border-color .25s ease, box-shadow .25s ease;
    display: block;
  }
  .ds-bundle-card:hover {
    transform: translateY(-3px);
    border-color: var(--color-accent);
    box-shadow: var(--shadow-md);
  }
  .ds-bundle-meta {
    font-family: var(--font-mono);
    font-size: 10px;
    text-transform: uppercase;
    letter-spacing: .06em;
    color: var(--color-ink-mute);
    margin-bottom: 12px;
  }
  .ds-bundle-card h3 {
    font-size: 18px;
    margin: 0 0 8px;
  }
  .ds-bundle-card p {
    font-size: 13px;
    color: var(--color-ink-soft);
    line-height: 1.55;
    margin: 0 0 16px;
  }
  .ds-bundle-price {
    font-family: var(--font-mono);
    font-size: 11px;
    color: var(--color-ink-mute);
    padding-top: 12px;
    border-top: 1px solid var(--color-line-soft);
  }
  .ds-bundle-cta {
    display: block;
    margin-top: 12px;
    font-size: 13px;
    color: var(--color-accent);
    font-weight: 500;
  }

  .ds-saving-table {
    background: var(--bg-card);
    border: 1px solid var(--line);
    border-radius: 14px;
    padding: 8px 24px;
  }
  .ds-saving-row {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 14px 0;
    font-size: 14px;
    color: var(--color-ink-soft);
  }
  .ds-saving-row .mono {
    font-family: var(--font-mono);
    color: var(--color-ink-soft);
  }
  .ds-saving-row.separator {
    border-top: 1px solid var(--color-line);
    color: var(--color-ink);
    font-weight: 500;
  }
  .ds-saving-row.separator .mono { color: var(--color-ink); }
  .ds-saving-row.highlight {
    color: var(--color-ink);
    font-weight: 600;
    font-size: 16px;
  }
  .ds-saving-row.highlight .mono { color: var(--color-ink); font-weight: 600; }
  .ds-saving-row.save {
    color: var(--color-accent);
    font-weight: 600;
    background: var(--color-accent-soft);
    margin: 4px -24px -8px;
    padding: 14px 24px;
    border-radius: 0 0 14px 14px;
  }
  .ds-saving-row.save .mono { color: var(--color-accent); font-weight: 700; }
  @media (max-width: 540px) {
    .ds-saving-table { padding: 8px 16px; }
    .ds-saving-row.save { margin: 4px -16px -8px; padding: 14px 16px; }
    .ds-saving-row { font-size: 13px; }
  }
</style>
</BaseLayout>
