{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://openswissdata.com/schemas/finma/v1",
  "title": "FINMA Registry Dataset",
  "description": "FINMA authorised institutions registry (unified across 10 source lists)",
  "type": "array",
  "items": {
    "type": "object",
    "required": ["entity_type", "name", "source_list", "source_url"],
    "properties": {
      "entity_type": {
        "enum": [
          "bank",
          "insurance",
          "asset_manager_collective",
          "asset_manager_individual",
          "securities_firm",
          "fund_representative",
          "payment_institution",
          "sro_member",
          "supervisory_org",
          "insurance_intermediary"
        ]
      },
      "name": { "type": "string" },
      "uid": { "type": "string", "pattern": "^CHE-\\d{3}\\.\\d{3}\\.\\d{3}$" },
      "lei": { "type": "string", "pattern": "^[A-Z0-9]{20}$" },
      "licence_type": { "type": "string" },
      "licence_date": { "type": "string", "format": "date" },
      "status": { "type": "string" },
      "canton": { "type": "string", "pattern": "^[A-Z]{2}$" },
      "address": { "type": "string" },
      "source_list": { "type": "string" },
      "source_url": { "type": "string", "format": "uri" }
    }
  }
}
