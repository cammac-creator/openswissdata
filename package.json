{
  "name": "openswissdata",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "db:migrate": "tsx src/db/migrate.ts",
    "db:seed": "node --env-file=.env --import tsx/esm src/db/seed.ts",
    "etl:tares": "tsx etl/tares/release.ts",
    "etl:classifications": "tsx etl/classifications/release.ts",
    "etl:finma": "tsx etl/finma/release.ts",
    "web:dev": "cd web && npx astro dev",
    "web:build": "cd web && npx astro build"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.700.0",
    "@aws-sdk/s3-request-presigner": "^3.700.0",
    "@hono/node-server": "^1.13.0",
    "archiver": "^7.0.1",
    "better-sqlite3": "^11.5.0",
    "csv-parse": "^6.2.1",
    "csv-stringify": "^6.7.0",
    "hono": "^4.6.0",
    "parquetjs-lite": "^0.8.7",
    "resend": "^4.0.0",
    "stripe": "^17.0.0",
    "xlsx": "^0.18.5",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/archiver": "^7.0.0",
    "@types/better-sqlite3": "^7.6.0",
    "@types/node": "^22.9.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  }
}
