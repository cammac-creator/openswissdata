PORT=3000
DATABASE_PATH=./data/openswissdata.sqlite
ADMIN_SECRET=change-me
SESSION_SECRET=change-me
BASE_URL=http://localhost:3000

STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx

RESEND_API_KEY=re_xxx
# noreply@ is a one-way sender. Replies bounce on this mailbox; clients should
# hit Reply-To: contact@ instead (set below). Both are aliases pointing at the
# Infomaniak contact@ mailbox in production, so a reply to either lands there.
RESEND_FROM_EMAIL=noreply@openswissdata.com
RESEND_REPLY_TO=contact@openswissdata.com

R2_ACCOUNT_ID=xxx
R2_ACCESS_KEY_ID=xxx
R2_SECRET_ACCESS_KEY=xxx
R2_BUCKET=openswissdata
R2_PUBLIC_URL=https://xxx.r2.cloudflarestorage.com

# Ed25519 signing key for ZIP provenance manifests.
# Generate via: node scripts/generate-signing-key.mjs (writes pubkey to packages/schemas/openswissdata.pubkey.ed25519)
# Value below is the base64 of a PKCS8 DER private key. NEVER commit a real value.
OSD_SIGNING_KEY_ED25519=

# MCP server — Bearer token used for the /mcp/* endpoints.
# Leave EMPTY in dev/test to disable auth. In production, set to a long random value.
# V2 will replace this with OAuth 2.1 + per-licence quotas.
MCP_BEARER_TOKEN=

# OAuth 2.1 — signing secret for /oauth/* access & refresh tokens.
# REQUIRED in production with ≥32 chars. Without it every authenticated MCP
# request returns HTTP 500. Generate via:
#   node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))"
OAUTH_SIGNING_SECRET=

# Watermarking secret for per-customer ZIP traceability.
# REQUIRED in production with ≥32 chars. Used to HMAC the per-licence
# manifest injected into each delivered ZIP and to derive deterministic
# canary record seeds. Rotate carefully — old manifests verified against
# the previous secret would fail. Generate via:
#   node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))"
WATERMARK_SECRET=
